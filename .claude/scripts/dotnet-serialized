#!/usr/bin/env bash
# Serialized dotnet wrapper — ensures only one dotnet build/test runs at a time.
# Uses mkdir-based locking (atomic on all platforms) so concurrent agents queue
# instead of OOM-ing the system.
#
# Drop-in replacement for `dotnet`: same arguments, same stdout/stderr, same exit code.
# The ONLY difference is that concurrent calls block until the lock is free.
#
# All stdout+stderr is tee'd to .claude/tmp/dotnet-serialized-{0,1,2}.log (rotating
# deque of 3). Agents can read these logs instead of re-running an 8-minute test suite.
# The symlink .claude/tmp/dotnet-serialized-latest.log always points to the current run.
#
# Usage:  .claude/scripts/dotnet-serialized build sharpy.sln --nologo -v q
#         .claude/scripts/dotnet-serialized test --filter "FullyQualifiedName~Lexer"

LOCK_DIR="${HOME}/.claude/locks/dotnet.lock"
TIMEOUT=900  # 15 minutes

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOG_DIR="${SCRIPT_DIR}/tmp"
LOG_DEQUE_SIZE=3
LOG_INDEX_FILE="${LOG_DIR}/dotnet-serialized-index"

cleanup() {
    rm -rf "$LOCK_DIR" 2>/dev/null
}

is_lock_stale() {
    local pid_file="$LOCK_DIR/pid"
    if [ ! -f "$pid_file" ]; then
        return 0
    fi
    local lock_pid
    lock_pid=$(cat "$pid_file" 2>/dev/null)
    if [ -z "$lock_pid" ]; then
        return 0
    fi
    if ! kill -0 "$lock_pid" 2>/dev/null; then
        return 0
    fi
    return 1
}

acquire_lock() {
    local waited=0
    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        if is_lock_stale; then
            echo "WARNING: Removing stale dotnet lock (owner PID gone)." >&2
            rm -rf "$LOCK_DIR" 2>/dev/null
            continue
        fi
        if [ "$waited" -ge "$TIMEOUT" ]; then
            echo "ERROR: Timed out waiting for dotnet lock after $((TIMEOUT/60)) minutes." >&2
            echo "Another dotnet command may be hung. Run: pkill -f dotnet" >&2
            exit 124
        fi
        sleep 2
        waited=$((waited + 2))
    done
    echo $$ > "$LOCK_DIR/pid"
    trap cleanup EXIT
}

next_log_slot() {
    mkdir -p "$LOG_DIR"
    local idx=0
    if [ -f "$LOG_INDEX_FILE" ]; then
        idx=$(cat "$LOG_INDEX_FILE" 2>/dev/null)
        idx=$(( (idx + 1) % LOG_DEQUE_SIZE ))
    fi
    echo "$idx" > "$LOG_INDEX_FILE"
    echo "$idx"
}

# Kill runaway csharp-ls processes (>80% CPU, >2 min) before acquiring the lock.
# csharp-ls often spins after builds due to file-watcher re-indexing on this large solution.
while IFS= read -r line; do
    pid=$(echo "$line" | awk '{print $2}')
    cpu=$(echo "$line" | awk '{print $3}')
    time_str=$(echo "$line" | awk '{print $10}')
    minutes=0
    if [[ "$time_str" =~ ^([0-9]+):([0-9]+):([0-9]+) ]]; then
        minutes=$(( ${BASH_REMATCH[1]} * 60 + ${BASH_REMATCH[2]} ))
    elif [[ "$time_str" =~ ^([0-9]+):([0-9]+) ]]; then
        minutes=${BASH_REMATCH[1]}
    fi
    cpu_int=${cpu%.*}
    if (( cpu_int >= 80 && minutes >= 2 )); then
        kill "$pid" 2>/dev/null && echo "Killed runaway csharp-ls PID $pid (CPU: ${cpu}%, time: ${time_str})" >&2
    fi
done < <(ps aux | grep '[c]sharp-ls' 2>/dev/null || true)

mkdir -p "${HOME}/.claude/locks"
acquire_lock

SLOT=$(next_log_slot)
LOG_FILE="${LOG_DIR}/dotnet-serialized-${SLOT}.log"

: > "$LOG_FILE"
ln -sf "dotnet-serialized-${SLOT}.log" "${LOG_DIR}/dotnet-serialized-latest.log"

dotnet "$@" 2>&1 | tee "$LOG_FILE"
EXIT_CODE=${PIPESTATUS[0]}

cleanup
trap - EXIT
exit $EXIT_CODE
