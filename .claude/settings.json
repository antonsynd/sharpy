{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-dotnet-serialized.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-secrets.sh",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_FILE_PATH\" | grep -qE '\\.(expected|error)$' && echo 'WARN: Editing test expectation file — are you sure the implementation is correct?' || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-on-save.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
