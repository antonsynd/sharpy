#!/usr/bin/env python3
import argparse
import logging
import subprocess
import sys
from pathlib import Path
from typing import AbstractSet, Mapping, MutableSequence, Sequence

_logger: logging.Logger = logging.getLogger(name="build_sharpy")

ROOT_DIR: Path = Path(__file__).parent.parent.parent
TOOLS_DIR: Path = ROOT_DIR / "tools"
DATA_DIR: Path = ROOT_DIR / "data"

SRC_DIR: Path = ROOT_DIR / "src"

COMPILER_DIR: Path = SRC_DIR / "Sharpy.Compiler"
COMPILER_TEST_DIR: Path = SRC_DIR / "Sharpy.Compiler.Tests"
CORE_DIR: Path = SRC_DIR / "Sharpy.Core"
CORE_TEST_DIR: Path = SRC_DIR / "Sharpy.Core.Tests"
CLI_DIR: Path = SRC_DIR / "Sharpy.Cli"

CSHARP_PROJECTS: Sequence[Path] = [
    COMPILER_DIR / "Sharpy.Compiler.csproj",
    CLI_DIR / "Sharpy.Cli.csproj",
    COMPILER_TEST_DIR / "Sharpy.Compiler.Tests.csproj",
    CORE_DIR / "Sharpy.Core.csproj",
    CORE_TEST_DIR / "Sharpy.Core.Tests.csproj",
]


def main() -> None:
    setup_logger()

    parser: argparse.ArgumentParser = create_parser()
    pre_args: MutableSequence[str] = []
    rest: MutableSequence[str] = []

    for i, arg in enumerate(sys.argv[1:], start=1):
        if arg == "--":
            rest.extend(sys.argv[i + 1 :])
            break

        pre_args.append(arg)

    args: argparse.Namespace = parser.parse_args(pre_args)

    command: str = args.command

    if command == "build":
        build(args=args, rest=rest, release=args.release)
    elif command == "setup":
        setup(args=args, rest=rest)
    elif command == "clean":
        clean(args=args, rest=rest)
    elif command == "install":
        install(args=args, rest=rest)
    elif command == "format":
        format(args=args, rest=rest)
    elif command == "debug":
        format(args=args, rest=rest)
        build(args=args, rest=rest, release=False)
        test(args=args, rest=rest, release=False)
    elif command == "release":
        format(args=args, rest=rest)
        build(args=args, rest=rest, release=False)
        test(args=args, rest=rest, release=False)
        build(args=args, rest=rest, release=True)
        test(args=args, rest=rest, release=True)
        install(args=args, rest=rest)
    elif command == "test":
        test(args=args, rest=rest, release=False)
    elif command == "help":
        parser.print_help()
    else:
        get_logger().error(f'Unknown command "{command}"')


def create_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="")
    subparsers = parser.add_subparsers(dest="command")

    _ = subparsers.add_parser("setup", help="Restores the project.")

    build_parser = subparsers.add_parser("build", help="Builds the package.")
    build_parser.add_argument(
        "--project",
        type=str,
        default="all",
        choices=("all", "compiler", "lib", "tests"),
    )
    build_parser.add_argument("--release", action="store_true")
    clean_parser = subparsers.add_parser(
        "clean", help="Cleans up intermediate objects."
    )
    clean_parser.add_argument(
        "--clean-resources", action="store_true", help="Cleans up generated resources."
    )
    _ = subparsers.add_parser("install", help="TODO: No-op")
    format_parser = subparsers.add_parser("format", help="Runs code formatters.")
    format_parser.add_argument(
        "--target",
        action="append",
        choices=("cs", "csharp", "rs", "rust"),
        default=None,
    )
    debug_parser = subparsers.add_parser("debug", help="Runs all steps.")
    debug_parser.add_argument(
        "--target",
        action="append",
        choices=("cs", "csharp", "rs", "rust"),
        default=None,
    )
    release_parser = subparsers.add_parser("release", help="Runs all steps.")
    release_parser.add_argument(
        "--target",
        action="append",
        choices=("cs", "csharp", "rs", "rust"),
        default=None,
    )
    test_parser = subparsers.add_parser("test", help="Runs tests.")
    test_parser.add_argument(
        "--target",
        action="append",
        choices=("cs", "csharp", "rs", "rust"),
        default=None,
    )
    _ = subparsers.add_parser("help", help="Prints this help message.")

    return parser


def get_targets(args: argparse.Namespace) -> AbstractSet[str]:
    if args.target:
        return set(args.target)

    return {"cs", "rs"}


def build(args: argparse.Namespace, rest: Sequence[str], release: bool) -> None:
    argdict: Mapping[str, str] = vars(args)

    if "project" not in argdict or argdict["project"] in {"all", "lib"}:
        build_lib(release=release)

    if "project" not in argdict or argdict["project"] in {"all", "compiler"}:
        build_compiler(release=release)

    if "project" not in argdict or argdict["project"] in {"all", "cli"}:
        build_cli(release=release)

    if "project" not in argdict or argdict["project"] in {"all", "tests"}:
        build_tests(release=release)


def build_cli(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(f"Building CLI with {build_type.lower()} configuration...")

        subprocess.run(["dotnet", "build", "-c", build_type, str(CLI_DIR)], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def build_compiler(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(
            f"Building compiler with {build_type.lower()} configuration..."
        )

        subprocess.run(
            ["dotnet", "build", "-c", build_type, str(COMPILER_DIR)], check=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def build_lib(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(
            f"Building standard library with {build_type.lower()} configuration..."
        )
        subprocess.run(["dotnet", "build", "-c", build_type, str(CORE_DIR)], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def build_tests(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(f"Building tests with {build_type.lower()} configuration...")
        subprocess.run(
            ["dotnet", "build", "-c", build_type, str(CORE_TEST_DIR)], check=True
        )
        subprocess.run(
            ["dotnet", "build", "-c", build_type, str(COMPILER_TEST_DIR)], check=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def setup(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Setting up...")
    get_logger().info("Restoring project...")

    try:
        subprocess.run(["dotnet", "restore"], check=True, cwd=ROOT_DIR)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def clean(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Cleaning project...")

    try:
        subprocess.run(["dotnet", "clean"], check=True, cwd=ROOT_DIR)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def install(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Nothing to install!")


def format(args: argparse.Namespace, rest: Sequence[str]) -> None:
    try:
        for project in CSHARP_PROJECTS:
            if not project.exists():
                get_logger().error(f"Project file '{project}' does not exist.")
                sys.exit(1)

            get_logger().info(
                f"Formatting source files from {project.name} with dotnet-format..."
            )
            subprocess.run(
                [
                    "dotnet",
                    "format",
                    "whitespace",
                    "-v",
                    "detailed",
                    str(project),
                ],
                check=True,
            )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def test(args: argparse.Namespace, rest: Sequence[str], release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    get_logger().info(
        f"Running tests with dotnet with {build_type.lower()} configuration..."
    )
    try:
        subprocess.run(
            ["dotnet", "test", "-c", build_type, str(CORE_TEST_DIR), *rest],
            check=True,
        )

        subprocess.run(
            ["dotnet", "test", "-c", build_type, str(COMPILER_TEST_DIR), *rest],
            check=True,
        )
    except subprocess.CalledProcessError as e:
        get_logger().error(f"Encountered error {e}")
        sys.exit(1)


def get_logger() -> logging.Logger:
    global _logger
    return _logger


def setup_logger() -> None:
    global _logger

    _logger.setLevel(
        logging.DEBUG
    )  # Set the base level to the lowest level you want to capture

    # Handler for stdout (INFO and DEBUG)
    _stdout_handler = logging.StreamHandler(sys.stdout)
    _stdout_handler.setLevel(logging.DEBUG)
    _stdout_handler.addFilter(
        lambda record: record.levelno <= logging.INFO
    )  # Filter for DEBUG and INFO

    # Handler for stderr (WARNING and ERROR)
    _stderr_handler = logging.StreamHandler(sys.stderr)
    _stderr_handler.setLevel(logging.WARNING)
    _stderr_handler.addFilter(
        lambda record: record.levelno >= logging.WARNING
    )  # Filter for WARNING and ERROR

    _formatter = logging.Formatter(
        "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )
    _stdout_handler.setFormatter(_formatter)
    _stderr_handler.setFormatter(_formatter)

    # Add handlers to the logger
    _logger.addHandler(_stdout_handler)
    _logger.addHandler(_stderr_handler)


def remove_pycache_dirs(root_path: Path):
    # Iterate over all __pycache__ directories recursively
    for pycache_dir in root_path.rglob("__pycache__"):
        if pycache_dir.is_dir():
            get_logger().info(f"Removing: {pycache_dir}")

            # Remove the __pycache__ directory
            for pycache_file in pycache_dir.iterdir():
                pycache_file.unlink()  # Remove the file

            pycache_dir.rmdir()  # Remove the directory itself


if __name__ == "__main__":
    main()
