#!/usr/bin/env python3
import argparse
import hashlib
import json
import logging
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import AbstractSet, Iterable, Mapping, MutableSequence, Sequence

import requests

_logger: logging.Logger = logging.getLogger(name="build_sharpy")

ROOT_DIR: Path = Path(__file__).parent.parent.parent
PYTHON_SRC_DIR: Path = ROOT_DIR / "python/src"
PYTHON_TEST_DIR: Path = ROOT_DIR / "python/test"
RESOURCE_DIR: Path = ROOT_DIR / "__resources"
TOOLS_DIR: Path = ROOT_DIR / "tools"
DATA_DIR: Path = ROOT_DIR / "data"

CSHARP_ROOT_DIR: Path = ROOT_DIR / "dotnet"
CSHARP_SRC_DIR: Path = ROOT_DIR / "dotnet/src/Sharpy"
CSHARP_DOCS_DIR: Path = ROOT_DIR / "dotnet/docs"
CSHARP_TEST_DIR: Path = ROOT_DIR / "dotnet/src/Sharpy.Tests"


_expected_resources: Sequence[Path] = [
    RESOURCE_DIR / "SharpyLexer.py",
    RESOURCE_DIR / "SharpyParserListener.py",
    RESOURCE_DIR / "SharpyParserVisitor.py",
]


def main() -> None:
    setup_logger()

    parser: argparse.ArgumentParser = create_parser()
    pre_args: MutableSequence[str] = []
    rest: MutableSequence[str] = []

    for i, arg in enumerate(sys.argv[1:], start=1):
        if arg == "--":
            rest.extend(sys.argv[i + 1 :])
            break

        pre_args.append(arg)

    args: argparse.Namespace = parser.parse_args(pre_args)

    command: str = args.command

    if command == "build":
        build(args=args, rest=rest, release=args.release)
    elif command == "setup":
        setup(args=args, rest=rest)
    elif command == "clean":
        clean(args=args, rest=rest)
    elif command == "install":
        install(args=args, rest=rest)
    elif command == "docs" or command == "build-docs":
        docs(args=args, rest=rest)
    elif command == "view-docs":
        view_docs(args=args, rest=rest)
    elif command == "format":
        format(args=args, rest=rest)
    elif command == "debug":
        format(args=args, rest=rest)
        build(args=args, rest=rest, release=False)
        test(args=args, rest=rest, release=False)
    elif command == "release":
        format(args=args, rest=rest)
        build(args=args, rest=rest, release=False)
        test(args=args, rest=rest, release=False)
        build(args=args, rest=rest, release=True)
        test(args=args, rest=rest, release=True)
        docs(args=args, rest=rest)
        install(args=args, rest=rest)
    elif command == "run":
        run(args=args, rest=rest)
    elif command == "test":
        test(args=args, rest=rest, release=False)
    elif command == "help":
        parser.print_help()
    else:
        get_logger().error(f'Unknown command "{command}"')


def create_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="")
    subparsers = parser.add_subparsers(dest="command")

    setup_parser = subparsers.add_parser(
        "setup", help="Downloads resources and generates required code."
    )
    build_parser = subparsers.add_parser("build", help="Builds the package.")
    build_parser.add_argument("--project", type=str, default="all", choices=("all", "lib", "tests"))
    build_parser.add_argument("--release", action="store_true")
    clean_parser = subparsers.add_parser("clean", help="Cleans up intermediate objects.")
    clean_parser.add_argument(
        "--clean-resources", action="store_true", help="Cleans up generated resources."
    )
    install_parser = subparsers.add_parser("install", help="TODO: No-op")
    format_parser = subparsers.add_parser("format", help="Runs code formatters.")
    format_parser.add_argument(
        "--target", action="append", choices=("cs", "csharp", "py", "python"), default=None
    )
    debug_parser = subparsers.add_parser("debug", help="Runs all steps.")
    debug_parser.add_argument(
        "--target", action="append", choices=("cs", "csharp", "py", "python"), default=None
    )
    release_parser = subparsers.add_parser("release", help="Runs all steps.")
    release_parser.add_argument(
        "--target", action="append", choices=("cs", "csharp", "py", "python"), default=None
    )
    run_parser = subparsers.add_parser(
        "run", help="Runs the given arguments in the context of the Python modules available here."
    )
    test_parser = subparsers.add_parser("test", help="Runs tests.")
    test_parser.add_argument(
        "--target", action="append", choices=("cs", "csharp", "py", "python"), default=None
    )
    build_docs_parser = subparsers.add_parser(
        "build-docs", aliases=["docs"], help="Generates documentation."
    )
    view_docs_parser = subparsers.add_parser(
        "view-docs", help="Starts the documentation server for viewing."
    )
    help_parser = subparsers.add_parser("help", help="Prints this help message.")

    return parser


def get_targets(args: argparse.Namespace) -> AbstractSet[str]:
    if args.target:
        return set(args.target)

    return {"py", "cs"}


def build(args: argparse.Namespace, rest: Sequence[str], release: bool) -> None:
    check_for_expected_resources()

    argdict: Mapping[str, str] = vars(args)

    if "project" not in argdict or argdict["project"] in {"all", "lib"}:
        build_lib(release=release)

    if "project" not in argdict or argdict["project"] in {"all", "tests"}:
        build_tests(release=release)


def build_lib(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(f"Building standard library with {build_type.lower()} configuration...")
        subprocess.run(["dotnet", "build", "-c", build_type, str(CSHARP_SRC_DIR)], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def build_tests(release: bool) -> None:
    build_type: str = "Release" if release else "Debug"

    try:
        get_logger().info(f"Building tests with {build_type.lower()} configuration...")
        subprocess.run(["dotnet", "build", "-c", build_type, str(CSHARP_TEST_DIR)], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def setup(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Setting up...")

    RESOURCE_DIR.mkdir(exist_ok=True)
    old_cwd: Path = Path.cwd()

    try:
        get_logger().info("Downloading resources...")
        download_data_files()

        get_logger().info("Generating lexer...")
        subprocess.run(
            [
                "antlr",
                "-o",
                str(RESOURCE_DIR),
                "-Dlanguage=Python3",
                str(DATA_DIR / "SharpyLexer.g4"),
            ],
            check=True,
        )

        get_logger().info("Generating parser and visitor...")
        subprocess.run(
            [
                "antlr",
                "-o",
                str(RESOURCE_DIR),
                "-visitor",
                "-Dlanguage=Python3",
                str(DATA_DIR / "SharpyParser.g4"),
            ],
            check=True,
        )

        get_logger().info("Copying lexer base to resources...")
        shutil.copyfile(
            src=DATA_DIR / "SharpyLexerBase.py",
            dst=RESOURCE_DIR / "SharpyLexerBase.py",
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        os.chdir(old_cwd)
        sys.exit(1)

    os.chdir(old_cwd)


def check_for_expected_resources() -> None:
    if not RESOURCE_DIR.exists():
        print(f"Resources not generated, please run 'setup' target", file=sys.stderr)
        sys.exit(1)

    missing_files: Sequence[Path] = []

    for file_path in _expected_resources:
        if not file_path.exists() or file_path.stat().st_size == 0:
            missing_files.append(file_path)

    if missing_files:
        print(f"Missing the following files:", file=sys.stderr)

        for file_path in missing_files:
            print(f"  {file_path}", file=sys.stderr)

        print(f"Please run 'setup' target", file=sys.stderr)
        sys.exit(1)


def download_data_files() -> None:
    download_files_from_jsons(specs=DATA_DIR.glob("*.json"), target_dir=RESOURCE_DIR)


def download_files_from_jsons(specs: Iterable[Path], target_dir: Path) -> None:
    for spec in specs:
        download_file_from_json(spec=spec, target_dir=target_dir)


def download_file_from_json(spec: Path, target_dir: Path) -> None:
    spec_json: Mapping[str, str] = json.loads(spec.read_text())
    url: str = spec_json["url"]
    dest_path: Path = target_dir / spec_json["destination"]
    expected_checksum: str = spec_json["checksum"]

    response: requests.Response = requests.get(url)

    if response.status_code != 200:
        print(
            f"Failed to download '{url}' with status code {response.status_code}", file=sys.stderr
        )
        sys.exit(1)

    retrieved_bytes: bytes = response.content
    actual_checksum: str = hashlib.sha256(retrieved_bytes).hexdigest()

    if expected_checksum != actual_checksum:
        print(
            f"Downloaded file '{url}' has checksum {actual_checksum}, but expected {expected_checksum}",
            file=sys.stderr,
        )
        sys.exit(1)

    dest_path.write_bytes(retrieved_bytes)


def clean(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Removing __pycache__ directories...")

    remove_pycache_dirs(root_path=PYTHON_SRC_DIR)
    remove_pycache_dirs(root_path=PYTHON_TEST_DIR)
    remove_pycache_dirs(root_path=RESOURCE_DIR)

    if args.clean_resources:
        get_logger().info("Removing generated resources...")

        for resource in RESOURCE_DIR.rglob("*"):
            resource.unlink()


def docs(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Generating documentation...")

    try:
        subprocess.run(["docfx", str(CSHARP_DOCS_DIR / "docfx.json")], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def view_docs(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Starting documentation server...")

    try:
        subprocess.run(["docfx", "serve", str(CSHARP_DOCS_DIR / "_site")], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def install(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Nothing to install!")


def format(args: argparse.Namespace, rest: Sequence[str]) -> None:
    targets: AbstractSet[str] = get_targets(args)

    if "py" in targets or "python" in targets:
        format_with_isort()
        format_with_black()

    if "cs" in targets or "csharp" in targets:
        format_with_dotnet_format()


def format_with_black() -> None:
    get_logger().info("Formatting with black...")

    try:
        subprocess.run(
            ["black", str(PYTHON_SRC_DIR), str(PYTHON_TEST_DIR), str(TOOLS_DIR)], check=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def format_with_isort() -> None:
    get_logger().info("Formatting with isort...")

    try:
        subprocess.run(
            ["isort", str(PYTHON_SRC_DIR), str(PYTHON_TEST_DIR), str(TOOLS_DIR)], check=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def format_with_dotnet_format() -> None:
    try:
        get_logger().info("Formatting source files with dotnet-format...")
        subprocess.run(
            [
                "dotnet",
                "format",
                "whitespace",
                "-v",
                "detailed",
                str(CSHARP_SRC_DIR / "Sharpy.csproj"),
            ],
            check=True,
        )

        get_logger().info("Formatting test files with dotnet-format...")
        subprocess.run(
            [
                "dotnet",
                "format",
                "whitespace",
                "-v",
                "detailed",
                str(CSHARP_TEST_DIR / "Sharpy.Tests.csproj"),
            ],
            check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"Encountered error {e}", file=sys.stderr)
        sys.exit(1)


def run(args: argparse.Namespace, rest: Sequence[str]) -> None:
    get_logger().info("Running custom command...")

    run_env: Mapping[str, str] = os.environ.copy()
    existing_python_path: str = run_env.get("PYTHONPATH", "")
    run_env["PYTHONPATH"] = ":".join([existing_python_path, str(PYTHON_SRC_DIR), str(RESOURCE_DIR)])

    try:
        subprocess.run(rest, env=run_env, check=True)
    except subprocess.CalledProcessError as e:
        get_logger().error(f"Encountered error {e}")
        sys.exit(1)


def test(args: argparse.Namespace, rest: Sequence[str], release: bool) -> None:
    targets: AbstractSet[str] = get_targets(args)

    if "py" in targets or "python" in targets:
        get_logger().info("Running tests with pytest...")

        try:
            subprocess.run(["pytest", str(PYTHON_TEST_DIR), *rest], check=True)
        except subprocess.CalledProcessError as e:
            get_logger().error(f"Encountered error {e}")
            sys.exit(1)

    if "cs" in targets or "csharp" in targets:
        build_type: str = "Release" if release else "Debug"

        get_logger().info(f"Running tests with dotnet with {build_type.lower()} configuration...")
        try:
            subprocess.run(
                ["dotnet", "test", "-c", build_type, str(CSHARP_TEST_DIR), *rest], check=True
            )
        except subprocess.CalledProcessError as e:
            get_logger().error(f"Encountered error {e}")
            sys.exit(1)


def get_logger() -> logging.Logger:
    global _logger
    return _logger


def setup_logger() -> None:
    global _logger

    _logger.setLevel(logging.DEBUG)  # Set the base level to the lowest level you want to capture

    # Handler for stdout (INFO and DEBUG)
    _stdout_handler = logging.StreamHandler(sys.stdout)
    _stdout_handler.setLevel(logging.DEBUG)
    _stdout_handler.addFilter(
        lambda record: record.levelno <= logging.INFO
    )  # Filter for DEBUG and INFO

    # Handler for stderr (WARNING and ERROR)
    _stderr_handler = logging.StreamHandler(sys.stderr)
    _stderr_handler.setLevel(logging.WARNING)
    _stderr_handler.addFilter(
        lambda record: record.levelno >= logging.WARNING
    )  # Filter for WARNING and ERROR

    _formatter = logging.Formatter("%(asctime)s - %(name)s - %(levelname)s - %(message)s")
    _stdout_handler.setFormatter(_formatter)
    _stderr_handler.setFormatter(_formatter)

    # Add handlers to the logger
    _logger.addHandler(_stdout_handler)
    _logger.addHandler(_stderr_handler)


def remove_pycache_dirs(root_path: Path):
    # Iterate over all __pycache__ directories recursively
    for pycache_dir in root_path.rglob("__pycache__"):
        if pycache_dir.is_dir():
            get_logger().info(f"Removing: {pycache_dir}")

            # Remove the __pycache__ directory
            for pycache_file in pycache_dir.iterdir():
                pycache_file.unlink()  # Remove the file

            pycache_dir.rmdir()  # Remove the directory itself


if __name__ == "__main__":
    main()
