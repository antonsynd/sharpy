# Control blocks
if True:
    pass
elif False:
    pass
elif False:
    pass
else:
    pass

while True:
    break

for i in [1, 2, 3]:
    if True:
        continue

    pass
else:
    pass

try:
    pass
except ValueError as e:
    pass
except Exception as e:
    pass
finally:
    pass

