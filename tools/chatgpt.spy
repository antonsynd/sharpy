import sys
import functools
import asyncio
from typing import Any, List, Dict, Tuple, Union


def main():
    # --- Literals ---
    integer = 42
    floating = 3.14
    string = "hello"
    boolean = True
    none_type = None
    complex_number = 3 + 4j

    # --- Expressions ---
    addition = integer + 10
    subtraction = floating - 1.0
    multiplication = integer * 2
    division = floating / 2
    floor_division = integer // 3
    modulus = integer % 5
    power = integer**2
    bitwise_and = integer & 1
    bitwise_or = integer | 2
    bitwise_xor = integer ^ 3
    bitwise_not = ~integer
    bitwise_shift_left = integer << 1
    bitwise_shift_right = integer >> 1
    logical_and = True and False
    logical_or = True or False
    logical_not = not True
    ternary = "yes" if boolean else "no"

    # --- Data Structures ---
    list_example = [1, 2, 3]
    tuple_example = (1, 2, 3)
    set_example = {1, 2, 3}
    dict_example = {"a": 1, "b": 2}
    list_comprehension = [x * 2 for x in range(5)]
    dict_comprehension = {x: x**2 for x in range(5)}
    set_comprehension = {x * 2 for x in range(5)}
    generator_expression = (x * 2 for x in range(5))

    # --- Control Flow ---
    if integer > 10:
        result = "big"
    elif integer == 10:
        result = "ten"
    else:
        result = "small"

    for i in range(5):
        pass

    while integer > 0:
        integer -= 1


# --- Functions & Lambdas ---
def add(a: int, b: int) -> int:
    return a + b


lambda_example = lambda x: x * 2


# --- Classes & OOP ---
class Base:
    def __init__(self, value: int):
        self.value = value

    def method(self) -> int:
        return self.value


class Derived(Base):
    def method(self) -> int:
        return super().method() + 1


# --- Exception Handling ---
def exception_handling():
    try:
        x = 1 / 0
    except ZeroDivisionError as e:
        x = 0
    finally:
        x += 1


# --- With Statement ---
def with_statements():
    with open("test.txt", "w") as f:
        f.write("Hello")


# --- Decorators ---
def decorator(func):
    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        return func(*args, **kwargs)

    return wrapper


@decorator
def decorated_function():
    return "Decorated!"


# --- Async Features ---
async def async_function():
    await asyncio.sleep(1)
    return "async result"


# --- Pattern Matching (Python 3.10+) ---
def match_example(value: Any):
    match value:
        case 1:
            return "One"
        case [x, y]:
            return f"List with {x} and {y}"
        case {"key": v}:
            return f"Dict with key={v}"
        case _:
            return "Something else"


# --- Metaprogramming ---
class Meta(type):
    def __new__(cls, name, bases, dct):
        dct["extra"] = lambda self: "extra method"
        return super().__new__(cls, name, bases, dct)


class MyClass(metaclass=Meta):
    pass


# --- Type Hints ---
def process(data: List[Dict[str, Union[int, float]]]) -> Tuple[int, float]:
    return len(data), sum(d["value"] for d in data)
