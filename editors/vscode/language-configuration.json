{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(def|class|struct|interface|enum|union|if|elif|else|for|while|try|except|finally|with|match|case|async\\s+def|lambda)\\b.*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(elif|else|except|finally|case)\\b"
  },
  "folding": {
    "offSide": true
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*:\\s*(#.*)?$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*(pass|return|break|continue|raise)\\b.*$",
      "action": {
        "indent": "outdent"
      }
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
