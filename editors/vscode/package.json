{
  "name": "sharpy-lang",
  "displayName": "Sharpy",
  "description": "Sharpy language support — diagnostics, hover, go-to-definition, and syntax highlighting",
  "version": "0.1.0",
  "publisher": "antonsynd",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sharpy"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sharpy",
        "extensions": [
          ".spy"
        ],
        "aliases": [
          "Sharpy",
          "sharpy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sharpy",
        "scopeName": "source.sharpy",
        "path": "./syntaxes/sharpy.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Sharpy",
      "properties": {
        "sharpy.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the sharpyc executable. If empty, uses 'sharpyc' from PATH."
        },
        "sharpy.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Sharpy language server."
        },
        "sharpy.lsp.maxNumberOfProblems": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of problems to show."
        },
        "sharpy.format.indentSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces per indent level."
        },
        "sharpy.inlayHints.typeAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred type annotations."
        },
        "sharpy.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter names at call sites."
        }
      }
    },
    "commands": [
      {
        "command": "sharpy.restartServer",
        "title": "Sharpy: Restart Language Server"
      },
      {
        "command": "sharpy.showOutputChannel",
        "title": "Sharpy: Show Output Channel"
      }
    ],
    "snippets": [
      {
        "language": "sharpy",
        "path": "./snippets/sharpy.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node esbuild.mjs --production",
    "watch:esbuild": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "prepackage": "npm run lint",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
