{
  "name": "sharpy-lang",
  "displayName": "Sharpy",
  "description": "Sharpy language support — diagnostics, hover, go-to-definition, and syntax highlighting",
  "version": "0.1.0",
  "publisher": "antonsynd",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sharpy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sharpy",
        "extensions": [
          ".spy"
        ],
        "aliases": [
          "Sharpy",
          "sharpy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sharpy",
        "scopeName": "source.sharpy",
        "path": "./syntaxes/sharpy.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Sharpy",
      "properties": {
        "sharpy.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the sharpyc executable. If empty, uses 'sharpyc' from PATH."
        },
        "sharpy.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Sharpy language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
