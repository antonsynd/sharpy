# Test decorator-based access modifiers

@private
def private_function():
    pass

@protected
def protected_function():
    pass

@internal
def internal_function():
    pass

@file
def file_function():
    pass

# Test underscore prefix fallback (when no decorator)
def _protected_by_prefix():
    pass

def __private_by_prefix():
    pass

# Test decorator override of prefix
@public
def _actually_public():
    pass

@internal
def __actually_internal():
    pass

# Test stacking with other decorators
@static
@private
def private_static_method():
    pass
