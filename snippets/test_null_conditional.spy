# Test null conditional operator (?.)

class Person:
    name: str
    age: int

    def __init__(self: Person, name: str, age: int):
        self.name = name
        self.age = age

    def greet(self: Person) -> str:
        return f"Hello, I'm {self.name}"

# Test 1: Null conditional member access on nullable field
def test_field_access():
    p: Person? = Person("Alice", 30)
    # age_nullable should be int?
    age_nullable = p?.age
    print(age_nullable)

# Test 2: Null conditional method call
def test_method_call():
    p: Person? = None()
    # greeting should be str?
    greeting = p?.greet()
    print(greeting)

# Test 3: Chained null conditional access
class Address:
    city: str

    def __init__(self: Address, city: str):
        self.city = city

class PersonWithAddress:
    name: str
    address: Address?

    def __init__(self: PersonWithAddress, name: str, address: Address?):
        self.name = name
        self.address = address

def test_chained():
    p: PersonWithAddress? = PersonWithAddress("Bob", None())
    # city should be str?
    city = p?.address?.city
    print(city)

# Test 4: Null conditional with null coalescing
def test_with_coalesce():
    p: Person? = None()
    # age should be int (not int?)
    age: int = p?.age ?? 0
    print(age)

# Test 5: Error case - using ?. on non-nullable type (should fail)
def test_error_non_nullable():
    p: Person = Person("Charlie", 25)
    # This should cause a compile error
    # age = p?.age  # ERROR: Person is not nullable

def main():
    test_field_access()
    test_method_call()
    test_chained()
    test_with_coalesce()
