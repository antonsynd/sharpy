# Simple Sharpy example demonstrating basic features

def square(x: int) -> int:
    return x * x

def main():
    # Loop with if/else
    for i in range(10):
        if i % 2 == 0:
            print("Even: ", i)
        else:
            print("Odd: ", i)

    # Function call
    print("Square of 5:", square(5))

    # List with type annotation
    numbers: list[float] = [2.0, 3.14, 42.0]
    print("Numbers:", numbers)
