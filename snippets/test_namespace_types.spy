# Test: Verify types generate at namespace level

counter: int = 0

class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

struct Vector:
    dx: float
    dy: float

interface IShape:
    def area(self) -> float:
        ...

enum Color:
    RED = 0
    GREEN = 1
    BLUE = 2

def helper() -> int:
    return counter

def main():
    p: Point = Point(1, 2)
    print(p.x)
    print(helper())
