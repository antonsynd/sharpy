# Function definitions (library module - no main() needed if imported)
# To run standalone, uncomment the main() function below

def foobar():
    pass


def add(x: int, y: int) -> int:
    return x + y


def fibonacci(n: int) -> int:
    if n == 0:
        return 0
    elif n == 1:
        return 1
    else:
        return fibonacci(n - 1) + fibonacci(n - 2)


def main():
    # Example usage
    foobar()
    print(add(3, 5))
    print(fibonacci(10))
