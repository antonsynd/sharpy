# Test hybrid access modifier system

# Test explicit access modifier keywords
public def public_function():
    pass

protected def protected_function():
    pass

private def private_function():
    pass

internal def internal_function():
    pass

file def file_function():
    pass

# Test underscore prefix system (should still work)
def _protected_method():
    pass

def __private_method():
    pass

# Test consistency - these should work
protected def _consistent_protected():
    pass

private def __consistent_private():
    pass

public def public_no_prefix():
    pass

# Test classes with explicit access modifiers
public class PublicClass:
    pass

private class PrivateClass:
    pass

# Test classes with prefix system
class _ProtectedClass:
    pass

class __PrivateClass:
    pass
