# Comprehensive type annotation tests
import system.collections.generic

class User:
    id: int
    name: str

    def __init__(self, id: int, name: str) -> None:
        self.id: int = id
        self.name: str = name


def main():
    # Simple types
    x: int = 5
    name: str = "hello"
    flag: bool = True

    # Generic types
    items: list[str] = ["a", "b"]
    mapping: dict[str, int] = {}
    nested: list[dict[str, bool]] = []

    # Complex combinations
    service: system.collections.generic.List[User] | None = None
    cache: system.collections.generic.Dictionary[str, system.collections.generic.List[User]] | None = None
