# Test error case: using ?. on non-nullable type

class Person:
    name: str
    age: int

    def __init__(self: Person, name: str, age: int):
        self.name = name
        self.age = age

def test_error():
    # This should fail: Person is not nullable
    p: Person = Person("Alice", 30)
    age = p?.age  # ERROR: should report that Person is not nullable
    print(age)

def main():
    test_error()
