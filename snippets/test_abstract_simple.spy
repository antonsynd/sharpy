# Test streamlined abstract method syntax

@abstract
class Base:
    # Implicit abstract - inline ellipsis in @abstract class
    def abstract_method(self) -> int: ...

    def concrete_method(self) -> int:
        return 100

class Derived(Base):
    @override
    def abstract_method(self) -> int:
        return 42

d = Derived()
print(d.abstract_method())
print(d.concrete_method())
