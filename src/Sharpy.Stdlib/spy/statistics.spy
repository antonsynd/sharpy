"""Mathematical statistics functions (mean, median, variance, etc.)."""

from sharpy import StatisticsError
from system import Math

def mean(data: list[float]) -> float:
    """Return the sample arithmetic mean of data."""
    values: list[float] = _materialize(data)
    return _sum(values) / len(values)

def fmean(data: list[float]) -> float:
    """Convert data to floats and compute the arithmetic mean."""
    return mean(data)

def median(data: list[float]) -> float:
    """Return the median (middle value) of numeric data."""
    sorted_data: list[float] = _materialize_sorted(data)
    n: int = len(sorted_data)
    mid: int = n // 2
    if n % 2 == 0:
        return (sorted_data[mid - 1] + sorted_data[mid]) / 2.0
    return sorted_data[mid]

def median_low(data: list[float]) -> float:
    """Return the low median of numeric data."""
    sorted_data: list[float] = _materialize_sorted(data)
    n: int = len(sorted_data)
    mid: int = n // 2
    if n % 2 == 0:
        return sorted_data[mid - 1]
    return sorted_data[mid]

def median_high(data: list[float]) -> float:
    """Return the high median of numeric data."""
    sorted_data: list[float] = _materialize_sorted(data)
    n: int = len(sorted_data)
    return sorted_data[n // 2]

def mode[T: notnull](data: list[T]) -> T:
    """Return the most common data point from discrete or nominal data."""
    counts: dict[T, int] = {}
    order: list[T] = []
    any_item: bool = False
    for item in data:
        any_item = True
        if item in counts:
            counts[item] = counts[item] + 1
        else:
            counts[item] = 1
            order.append(item)
    if not any_item:
        raise StatisticsError("no data")
    best_value: T = order[0]
    best_count: int = counts[best_value]
    i: int = 1
    while i < len(order):
        candidate: T = order[i]
        candidate_count: int = counts[candidate]
        if candidate_count > best_count:
            best_value = candidate
            best_count = candidate_count
        i = i + 1
    return best_value

def stdev(data: list[float]) -> float:
    """Return the square root of the sample variance."""
    return Math.sqrt(variance(data))

def pstdev(data: list[float]) -> float:
    """Return the square root of the population variance."""
    return Math.sqrt(pvariance(data))

def variance(data: list[float]) -> float:
    """Return the sample variance of data."""
    values: list[float] = _materialize(data)
    if len(values) < 2:
        raise StatisticsError("variance requires at least two data points")
    m: float = _sum(values) / len(values)
    ss: float = _sum_of_squared_deviations(values, m)
    return ss / (len(values) - 1)

def pvariance(data: list[float]) -> float:
    """Return the population variance of data."""
    values: list[float] = _materialize(data)
    m: float = _sum(values) / len(values)
    ss: float = _sum_of_squared_deviations(values, m)
    return ss / len(values)

def _materialize(data: list[float]) -> list[float]:
    """Copy data to a new list, raising StatisticsError if empty."""
    result: list[float] = list(data)
    if len(result) == 0:
        raise StatisticsError("no data")
    return result

def _materialize_sorted(data: list[float]) -> list[float]:
    """Copy data to a sorted list, raising StatisticsError if empty."""
    result: list[float] = _materialize(data)
    result.sort()
    return result

def _sum(values: list[float]) -> float:
    """Return the sum of all values in the list."""
    total: float = 0.0
    for v in values:
        total = total + v
    return total

def _sum_of_squared_deviations(values: list[float], m: float) -> float:
    """Return the sum of squared deviations from the mean m."""
    ss: float = 0.0
    for v in values:
        diff: float = v - m
        ss = ss + diff * diff
    return ss

def _ints_to_floats(data: list[int]) -> list[float]:
    """Convert a list of ints to a list of floats."""
    result: list[float] = []
    for v in data:
        result.append(float(v))
    return result

def _longs_to_floats(data: list[long]) -> list[float]:
    """Convert a list of longs to a list of floats."""
    result: list[float] = []
    for v in data:
        result.append(float(v))
    return result

def mean(data: list[int]) -> float:
    """Return the sample arithmetic mean of integer data."""
    return mean(_ints_to_floats(data))

def mean(data: list[long]) -> float:
    """Return the sample arithmetic mean of long integer data."""
    return mean(_longs_to_floats(data))

def fmean(data: list[int]) -> float:
    """Convert integer data to floats and compute the arithmetic mean."""
    return mean(_ints_to_floats(data))

def fmean(data: list[long]) -> float:
    """Convert long integer data to floats and compute the arithmetic mean."""
    return mean(_longs_to_floats(data))

def median(data: list[int]) -> float:
    """Return the median (middle value) of integer data."""
    return median(_ints_to_floats(data))

def median(data: list[long]) -> float:
    """Return the median (middle value) of long integer data."""
    return median(_longs_to_floats(data))

def stdev(data: list[int]) -> float:
    """Return the square root of the sample variance for integer data."""
    return stdev(_ints_to_floats(data))

def stdev(data: list[long]) -> float:
    """Return the square root of the sample variance for long integer data."""
    return stdev(_longs_to_floats(data))

def variance(data: list[int]) -> float:
    """Return the sample variance of integer data."""
    return variance(_ints_to_floats(data))

def variance(data: list[long]) -> float:
    """Return the sample variance of long integer data."""
    return variance(_longs_to_floats(data))

def pstdev(data: list[int]) -> float:
    """Return the square root of the population variance for integer data."""
    return pstdev(_ints_to_floats(data))

def pstdev(data: list[long]) -> float:
    """Return the square root of the population variance for long integer data."""
    return pstdev(_longs_to_floats(data))

def pvariance(data: list[int]) -> float:
    """Return the population variance of integer data."""
    return pvariance(_ints_to_floats(data))

def pvariance(data: list[long]) -> float:
    """Return the population variance of long integer data."""
    return pvariance(_longs_to_floats(data))
