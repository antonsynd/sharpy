"""Text comparison and diffing utilities, matching Python's difflib module."""

# SequenceMatcher and Differ are fully implemented in C#
# (src/Sharpy.Stdlib/Difflib/) and re-exported here.
from sharpy import SequenceMatcher, Differ
from sharpy import ValueError

