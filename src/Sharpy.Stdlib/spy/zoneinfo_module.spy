"""IANA time zone support."""

from sharpy import ZoneInfo, ZoneInfoNotFoundError
from system import TimeZoneInfo

def available_timezones() -> set[str]:
    """Return a set of all available IANA time zone keys."""
    result: set[str] = set()
    for tz in TimeZoneInfo.get_system_time_zones():
        result.add(tz.Id)
    return result
