<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <RootNamespace>Sharpy</RootNamespace>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Sharpy.Stdlib.Spy</AssemblyName>
    <NoWarn>SPY0452,SPY0453</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <SourceFile Include="*.spy" />
  </ItemGroup>
</Project>
