using System;
using System.Collections;
using System.Collections.Generic;
using System.Numerics;

namespace Sharpy.Stdlib
{
    public sealed class Range<T = int> where T : struct, INumber<T> : IEnumerable<T>
    {
        public T Start { get; init; }
        public T Stop { get; init; }
        public T Step { get; init; }

        public Range(T start, T stop, T step = 1)
        {
            if (step == 0)
            {
                throw new ArgumentException("Step cannot be zero.", nameof(step));
            }

            Start = start;
            Stop = stop;
            Step = step;
        }

        public Range(T stop) : this(0, stop) { }

        public IEnumerator<int> GetEnumerator()
        {
            for (int i = Start; (Step > 0 ? i < Stop : i > Stop); i += Step)
            {
                yield return i;
            }
        }

        /// <summary>
        /// Delegate to specialized GetEnumerator() for generalized one.
        /// </summary>
        IEnumerator IEnumerable.GetEnumerator() => GetEnumerator();

        public bool Contains(T value)
        {
            // TODO
            return false;
        }

        public int Index(T value)
        {
            // TODO
            return -1;
        }

        public int Len()
        {
            // TODO
            return 0;
        }

        public int Count(T value)
        {
            // TODO
            return 0;
        }

        public static bool operator ==(Range<T> left, Range<T> right)
        {
            // TODO
            return false;
        }

        public static bool operator !=(Range<T> left, Range<T> right) { return !(left == right); }

        public override bool Equals(object obj)
        {
            if (obj is Range<T> other)
            {
                return this == other;
            }

            return false;
        }

        public override int GetHashCode()
        {
            return HashCode.Combine(Start, Stop, Step);
        }


        // reversed


        // 11 in r
        // r.index(10)
        // r[5]
        // r[:5]
        // r[-1]
        // len(r)
        // reversed(r)
        // r.count(5)
        // equality on sequence, not start/stop/step values
    }
}
