# Test: Variable name collision in class methods
# Verifies that user-declared x_1 (mangled to x1) does not conflict with
# generated versioned names in class methods.

class Counter:
    value: int

    def __init__(self, start: int):
        self.value = start

    def increment(self) -> str:
        x: int = self.value
        x_1: str = "marker"      # User's x_1 (mangled to x1)
        x: int = x + 1           # Redeclaration: generates x_1
        self.value = x
        return x_1               # Returns user's marker (x1)

def main():
    c: Counter = Counter(10)
    result = c.increment()
    print(c.value)
    print(result)
