from base_shape import ShapeBase

class Rectangle(ShapeBase):
    width: int
    height: int

    def __init__(self, w: int, h: int):
        super().__init__("Rectangle")
        self.width = w
        self.height = h

    @override
    def area(self) -> int:
        return self.width * self.height

    @override
    def perimeter(self) -> int:
        return 2 * (self.width + self.height)

def main():
    r = Rectangle(5, 3)
    print(r.describe())
    print(r.area())
    print(r.perimeter())
