# Test that @test functions can reference user-defined classes in the same file

class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def sum(self) -> int:
        return self.x + self.y

@test
def test_point_creation():
    p: Point = Point(3, 4)
    assert p.sum() == 7

def main():
    print("ok")
