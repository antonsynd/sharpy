@test
def test_equality():
    x: int = 1
    y: int = 2
    assert x == y
    assert x != y

@test
def test_comparisons():
    x: int = 1
    y: int = 2
    assert x > y
    assert x < y
    assert x >= y
    assert x <= y

@test
def test_nullability():
    s: str? = None()
    assert s is None
    assert s is not None

@test
def test_membership():
    items: list[int] = [1, 2, 3]
    assert 1 in items
    assert 4 not in items

class Widget:
    name: str

    def __init__(self, name: str):
        self.name = name

@test
def test_none_equality():
    # NoneCheck-classified operand (a class-UDT instance, not Optional/str?): == None / != None
    # rewrite to Assert.Null/NotNull. Deliberately contradictory — snapshot-only, never executed.
    w: Widget = Widget("gadget")
    assert w == None
    assert w != None

def main():
    print("ok")
