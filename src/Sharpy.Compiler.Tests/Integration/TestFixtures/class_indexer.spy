class MyMap:
    _data: dict[str, int]

    def __init__(self):
        self._data = {}

    def __getitem__(self, key: str) -> int:
        return self._data[key]

    def __setitem__(self, key: str, value: int) -> None:
        self._data[key] = value

def main():
    m: MyMap = MyMap()
    m["a"] = 10
    m["b"] = 20
    print(m["a"])
    print(m["b"])
    m["a"] += 5
    print(m["a"])
