# Generic module-qualified constructor calls (#880): a generic exported type
# can be instantiated as module.Type[T](args), and annotated as a generic
# module-qualified type module.Type[T] in annotation position (#881).
import containers

def main() -> None:
    b: containers.Box[int] = containers.Box[int](42)
    print(b.get())

    s: containers.Box[str] = containers.Box[str]("hello")
    print(s.get())
