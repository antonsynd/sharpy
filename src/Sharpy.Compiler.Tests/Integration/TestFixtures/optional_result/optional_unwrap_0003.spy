# Test optional unwrap method
def main():
    # Test unwrap on Some value
    x: int? = Some(42)
    print(x.unwrap())
    
    # Test unwrap_or with Some value
    y: int? = Some(100)
    print(y.unwrap_or(0))
    
    # Test unwrap_or with None value
    z: int? = None()
    print(z.unwrap_or(999))
    
    # Test with string optional
    name: str? = Some("Alice")
    print(name.unwrap())

# EXPECTED OUTPUT:
# 42
# 100
# 999
# Alice