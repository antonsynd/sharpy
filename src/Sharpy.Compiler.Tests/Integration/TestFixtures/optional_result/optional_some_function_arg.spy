# Test: Some(value) and None() passed as function arguments to T? parameters (regression guard)
def greet(name: str, title: str? = None()) -> str:
    if title is not None:
        return f"Hello, {title} {name}"
    return f"Hello, {name}"

def process(a: int, b: int? = None()) -> int:
    if b is not None:
        return a + b
    return a

def main():
    print(greet("Alice", Some("Dr.")))
    print(greet("Bob"))
    print(greet("Charlie", None()))
    print(process(10, Some(5)))
    print(process(10))
    print(process(10, None()))
