# Test: invariant interface rejection with user-defined type arguments (#827)
# IList[T] is invariant in T, so list[Dog] cannot be passed where IList[Animal]
# is expected.
# The Sharpy type checker correctly rejects this at the semantic level (SPY0220)
# because IList[T] is invariant and Dog is not the same type as Animal.

from system.collections.generic import IList

class Animal:
    pass

class Dog(Animal):
    pass

def mutate(items: IList[Animal]) -> None:
    pass

def main():
    dogs: list[Dog] = [Dog()]
    mutate(dogs)
