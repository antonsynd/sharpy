class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __str__(self) -> str:
        return f"({self.x}, {self.y})"

class Box[T]:
    value: T

    def __init__(self, value: T):
        self.value = value

    def get(self) -> T:
        return self.value
