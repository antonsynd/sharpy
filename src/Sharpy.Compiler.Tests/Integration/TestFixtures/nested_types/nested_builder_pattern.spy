class Config:
    host: str
    port: int

    def __init__(self, host: str, port: int):
        self.host = host
        self.port = port

    def __str__(self) -> str:
        return self.host + ":" + str(self.port)

    @public
    class Builder:
        host: str
        port: int

        def __init__(self):
            self.host = "localhost"
            self.port = 8080

        def with_host(self, host: str) -> Config.Builder:
            self.host = host
            return self

        def with_port(self, port: int) -> Config.Builder:
            self.port = port
            return self

        def build(self) -> Config:
            return Config(self.host, self.port)

def main():
    cfg: Config = Config.Builder().with_host("example.com").with_port(443).build()
    print(cfg)
