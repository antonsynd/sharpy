# Test class initialization with multiple fields and basic operations
class Rectangle:
    width: int
    height: int

    def __init__(self, w: int, h: int):
        self.width = w
        self.height = h

    def area(self) -> int:
        return self.width * self.height

r = Rectangle(5, 3)
print(r.width)
print(r.height)
print(r.area())
