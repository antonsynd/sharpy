# Test iterator protocol collision with Dispose

class MyIterator:
    index: int

    def __init__(self):
        self.index = 0

    # This should trigger SPY0522 for 'dispose' -> 'Dispose'
    def dispose(self) -> None:
        pass

    def __next__(self) -> int:
        result: int = self.index
        self.index += 1
        return result

def main():
    it: MyIterator = MyIterator()
    # This file should fail at compile time due to name collision
