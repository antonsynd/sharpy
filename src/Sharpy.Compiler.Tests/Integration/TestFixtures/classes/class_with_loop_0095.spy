# Test: Class with while loops for generating multiplication table
class MultiplicationTable:
    size: int

    def __init__(self, n: int):
        self.size = n

    def print_row(self, row: int) -> None:
        col: int = 1
        while col <= self.size:
            product: int = row * col
            print(product)
            col += 1

def main():
    table = MultiplicationTable(3)
    i: int = 1
    while i <= table.size:
        table.print_row(i)
        i += 1
