class Calculator:
    def __init__(self):
        pass

    def add(self, a: int) -> int:
        return a

    def add(self, a: int, b: int) -> int:
        return a + b

    def add(self, a: int, b: int, c: int) -> int:
        return a + b + c

def main():
    c: Calculator = Calculator()
    print(c.add(10))
    print(c.add(1, 2))
    print(c.add(1, 2, 3))
