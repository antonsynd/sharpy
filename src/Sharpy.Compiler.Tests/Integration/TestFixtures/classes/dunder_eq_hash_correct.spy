# Both __eq__(self, other: object) and __hash__ defined — no error expected
class Foo:
    x: int

    def __init__(self, x: int):
        self.x = x

    def __eq__(self, other: object) -> bool:
        if other is Foo:
            return self.x == (other as Foo).x
        return False

    def __hash__(self) -> int:
        return self.x

def main():
    a = Foo(42)
    b = Foo(42)
    print(a == b)
    print(a == Foo(99))
