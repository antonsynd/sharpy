# Test class with loop: Counter that sums numbers using a loop

class Accumulator:
    total: int

    def __init__(self):
        self.total = 0

    def sum_to(self, n: int) -> int:
        for i in range(1, n + 1):
            self.total += i
        return self.total

def main():
    acc = Accumulator()
    result = acc.sum_to(5)
    print(result)
    print(acc.total)

    # EXPECTED OUTPUT:
    # 15
    # 15
