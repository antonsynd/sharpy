class PathJoiner:
    def __init__(self):
        pass

    def join(self, a: str, b: str) -> str:
        return a + "/" + b

    def join(self, *parts: str) -> str:
        result: str = ""
        for p in parts:
            if result != "":
                result = result + "/"
            result = result + p
        return result

def main():
    joiner: PathJoiner = PathJoiner()
    print(joiner.join("a", "b"))
    print(joiner.join("a", "b", "c"))
