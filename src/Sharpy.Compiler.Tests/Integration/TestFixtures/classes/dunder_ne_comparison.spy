# Test __ne__ and all comparison dunders together
class Priority:
    level: int

    def __init__(self, level: int):
        self.level = level

    def __eq__(self, other: object) -> bool:
        if isinstance(other, Priority):
            return self.level == other.level
        return False

    def __ne__(self, other: object) -> bool:
        if isinstance(other, Priority):
            return self.level != other.level
        return True

    def __lt__(self, other: Priority) -> bool:
        return self.level < other.level

    def __le__(self, other: Priority) -> bool:
        return self.level <= other.level

    def __gt__(self, other: Priority) -> bool:
        return self.level > other.level

    def __ge__(self, other: Priority) -> bool:
        return self.level >= other.level

    def __hash__(self) -> int:
        return hash(self.level)

def main():
    low: Priority = Priority(1)
    med: Priority = Priority(5)
    high: Priority = Priority(10)
    same: Priority = Priority(5)

    print(low != med)
    print(med != same)
    print(low < med)
    print(high >= med)
    print(low == med)
    print(med == same)
