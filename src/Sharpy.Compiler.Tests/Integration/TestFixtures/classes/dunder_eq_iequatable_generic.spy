class Box[T]:
    value: T

    def __init__(self, value: T):
        self.value = value

    def __eq__(self, other: Box[T]) -> bool:
        return self.value == other.value

def main():
    a = Box[int](42)
    b = Box[int](42)
    c = Box[int](99)

    # Test operator == routes through Equals(Box<T>)
    print(a == b)
    print(a == c)

    # Test operator !=
    print(a != b)
    print(a != c)
