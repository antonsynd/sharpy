# Test __getitem__, __setitem__, and __contains__ operator overloading
class Inventory:
    _items: dict[str, int]

    def __init__(self):
        self._items = {}

    def __getitem__(self, key: str) -> int:
        return self._items[key]

    def __setitem__(self, key: str, value: int):
        self._items[key] = value

    def __contains__(self, key: str) -> bool:
        return key in self._items

def main():
    inv: Inventory = Inventory()
    inv["apples"] = 5
    inv["bananas"] = 3
    print(inv["apples"])
    print(inv["bananas"])
    print("apples" in inv)
    print("oranges" in inv)
