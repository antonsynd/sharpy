class Token:
    value: int

    def __init__(self, value: int):
        self.value = value

    def __eq__(self, other: object) -> bool:
        return False

    def __hash__(self) -> int:
        return self.value

def main():
    a = Token(1)
    b = Token(1)
    c = Token(2)
    # __eq__(object) generates override Equals(object), NOT IEquatable
    print(a == b)
    print(a == c)
    print(a != c)
