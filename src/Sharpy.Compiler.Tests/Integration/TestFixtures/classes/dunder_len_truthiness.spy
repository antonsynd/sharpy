# Class with __len__ but no __bool__, shows fallback to count-based truthiness
class Bag:
    items: list[int]

    def __init__(self):
        self.items = []

    def add(self, item: int):
        self.items.append(item)

    def __len__(self) -> int:
        return len(self.items)

def main():
    b = Bag()
    print(bool(b))
    b.add(42)
    print(bool(b))
