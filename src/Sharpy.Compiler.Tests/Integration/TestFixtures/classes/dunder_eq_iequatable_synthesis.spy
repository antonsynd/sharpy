class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __eq__(self, other: Point) -> bool:
        return self.x == other.x and self.y == other.y

def main():
    a = Point(1, 2)
    b = Point(1, 2)
    c = Point(3, 4)

    # Test operator == routes through virtual Equals(Point)
    print(a == b)
    print(a == c)

    # Test operator != (complementary, routes through Equals(Point))
    print(a != b)
    print(a != c)
