class Counter:
    count: int

    def __init__(self):
        self.count = 0

    def __next__(self) -> int:
        self.count += 1
        return self.count

    # User-defined get_enumerator mangles to GetEnumerator,
    # which collides with synthesized iterator protocol member
    def get_enumerator(self) -> None:
        pass

def main():
    c: Counter = Counter()
    print(next(c))
