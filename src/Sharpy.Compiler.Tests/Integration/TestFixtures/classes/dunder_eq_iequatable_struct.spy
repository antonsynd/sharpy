struct Vec2:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __eq__(self, other: Vec2) -> bool:
        return self.x == other.x and self.y == other.y

def main():
    a = Vec2(1, 2)
    b = Vec2(1, 2)
    c = Vec2(3, 4)
    print(a == b)
    print(a == c)
    print(a != b)
    print(a != c)
