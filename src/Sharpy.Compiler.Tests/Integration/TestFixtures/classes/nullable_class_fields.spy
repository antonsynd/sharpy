# Test nullable (T | None) types as class fields and method parameters

class ScoreEvaluator:
    passing_grade: int

    def __init__(self, passing: int):
        self.passing_grade = passing

    def evaluate(self, score: int | None) -> str:
        if score is None:
            return "No score recorded"
        else:
            if score >= self.passing_grade:
                return "Pass"
            else:
                return "Fail"

    def get_status(self, score: int | None) -> int:
        if score is None:
            return 0
        else:
            if score >= self.passing_grade:
                return 1
            else:
                return 2

def main():
    evaluator = ScoreEvaluator(60)

    test_score_1: int | None = 75
    result_1 = evaluator.evaluate(test_score_1)
    print(result_1)
    status_1 = evaluator.get_status(test_score_1)
    print(status_1)

    test_score_2: int | None = 45
    result_2 = evaluator.evaluate(test_score_2)
    print(result_2)
    status_2 = evaluator.get_status(test_score_2)
    print(status_2)

    test_score_3: int | None = None
    result_3 = evaluator.evaluate(test_score_3)
    print(result_3)
    status_3 = evaluator.get_status(test_score_3)
    print(status_3)
