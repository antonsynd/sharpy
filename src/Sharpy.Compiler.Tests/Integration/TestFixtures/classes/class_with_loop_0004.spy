# Test class with loop - counter with iteration
class Counter:
    count: int

    def __init__(self, start: int):
        self.count = start

    def increment_times(self, times: int) -> None:
        i: int = 0
        while i < times:
            self.count += 1
            i += 1

def main():
    c = Counter(5)
    c.increment_times(3)
    print(c.count)

    # EXPECTED OUTPUT:
    # 8
