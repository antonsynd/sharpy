# Test set in-place mutation methods
def main():
    # Update (in-place union)
    s: set[int] = {1, 2, 3}
    s.update({3, 4, 5})
    sl: list[int] = list(s)
    print(sorted(sl))

    # Difference update (in-place difference)
    s2: set[int] = {1, 2, 3, 4, 5}
    s2.difference_update({3, 4})
    sl2: list[int] = list(s2)
    print(sorted(sl2))

    # Intersection update (in-place intersection)
    s3: set[int] = {1, 2, 3, 4, 5}
    s3.intersection_update({2, 4, 6})
    sl3: list[int] = list(s3)
    print(sorted(sl3))

    # Symmetric difference update (in-place symmetric difference)
    s4: set[int] = {1, 2, 3}
    s4.symmetric_difference_update({2, 3, 4})
    sl4: list[int] = list(s4)
    print(sorted(sl4))
