# Test: reference-type nullable field narrowing with early return (is None guard)
class Wrapper:
    _name: str | None

    def __init__(self, name: str | None):
        self._name = name

    def greet(self) -> str:
        if self._name is None:
            return "anonymous"
        return "Hello, " + self._name

def main():
    w1: Wrapper = Wrapper("Alice")
    w2: Wrapper = Wrapper(None)
    print(w1.greet())
    print(w2.greet())
