from system import IEquatable, IComparable

class Point(IEquatable[Point], IComparable[Point]):
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __eq__(self, other: Point) -> bool:
        return self.x == other.x and self.y == other.y

    def compare_to(self, other: Point) -> int:
        dist_self: int = self.x * self.x + self.y * self.y
        dist_other: int = other.x * other.x + other.y * other.y
        return dist_self - dist_other

def main():
    a = Point(1, 2)
    b = Point(1, 2)
    c = Point(3, 4)
    print(a == b)
    print(a == c)
    print(a.compare_to(c) < 0)
