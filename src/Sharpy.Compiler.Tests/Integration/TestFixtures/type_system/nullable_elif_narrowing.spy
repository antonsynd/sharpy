def check(x: int | None, y: int | None) -> str:
    if x is not None and y is not None:
        return f"both: {x + y}"
    elif x is not None:
        return f"x only: {x}"
    elif y is not None:
        return f"y only: {y}"
    else:
        return "neither"

def main():
    print(check(10, 20))
    print(check(5, None))
    print(check(None, 7))
    print(check(None, None))
