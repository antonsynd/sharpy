# Test value-type nullable narrowing: int | None -> int via is not None
def main():
    x: int | None = 42
    if x is not None:
        y: int = x + 1
        print(y)

    # Also test with is None for else-branch narrowing
    z: int | None = None
    if z is None:
        print("z is null")
    else:
        w: int = z + 10
        print(w)
