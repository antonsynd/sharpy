def main():
    # Augmented assignment on narrowed nullable should work
    x: int | None = 10
    if x is not None:
        x += 5
        print(x)

    y: int | None = 20
    if y is not None:
        y -= 3
        print(y)

    z: int | None = 6
    if z is not None:
        z *= 7
        print(z)

    # Augmented assignment with modulo
    w: int | None = 17
    if w is not None:
        w %= 5
        print(w)
