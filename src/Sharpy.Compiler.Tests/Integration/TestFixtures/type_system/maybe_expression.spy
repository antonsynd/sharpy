# Test maybe expression: converts C# nullable (T | None) to Optional<T>

def convert_str(raw: str | None) -> str?:
    return maybe raw

def convert_int(raw: int | None) -> int?:
    return maybe raw

def main():
    # Non-null string
    a: str? = convert_str("hello")
    print(a.is_some)
    print(a ?? "none")

    # Null string
    b: str? = convert_str(None)
    print(b.is_none)
    print(b ?? "fallback")

    # Non-null int
    c: int? = convert_int(42)
    print(c ?? 0)

    # Null int
    d: int? = convert_int(None)
    print(d ?? -1)
