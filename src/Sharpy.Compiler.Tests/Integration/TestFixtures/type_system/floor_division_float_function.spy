# Test floor division with float-returning functions.
# Ensures IsFloatExpression consults SemanticInfo for resolved types
# rather than guessing from AST shape.

def get_float() -> float:
    return 7.5

def get_neg_float() -> float:
    return -7.5

def main():
    # Floor division with float function result
    print(get_float() // 2.0)
    print(get_float() // 2)

    # Floor division with literal floats (existing behavior)
    print(7.5 // 2.0)

    # Floor toward negative infinity
    print(get_neg_float() // 2.0)
    print(get_neg_float() // 2)
