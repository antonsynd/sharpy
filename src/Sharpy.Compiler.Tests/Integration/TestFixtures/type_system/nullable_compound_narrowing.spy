def main():
    x: int | None = 10
    y: int | None = 20

    # Compound and: both should be narrowed in then-body
    if x is not None and y is not None:
        print(x + y)
    else:
        print("none")

    # Only one narrowed
    z: int | None = None
    if x is not None and z is not None:
        print("both present")
    else:
        print("not both")
