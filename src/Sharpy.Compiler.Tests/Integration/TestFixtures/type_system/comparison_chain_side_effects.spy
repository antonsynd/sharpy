# Test that intermediate expressions in comparison chains are evaluated exactly once.
# Python guarantees single evaluation of intermediate expressions.

class Counter:
    value: int

    def __init__(self):
        self.value = 0

    def increment(self) -> int:
        self.value = self.value + 1
        return self.value

def main():
    c: Counter = Counter()

    # increment() should be called exactly once
    # c.value starts at 0, increment returns 1
    # 0 < 1 < 3 → True
    result: bool = 0 < c.increment() < 3
    print(result)
    print(c.value)

    # Reset and test with a chain where the first comparison is false
    c2: Counter = Counter()
    # increment() returns 1; 10 < 1 → False, short-circuits
    result2: bool = 10 < c2.increment() < 20
    print(result2)
    print(c2.value)

    # Simple chain with identifiers (no side effects, should still work)
    x: int = 1
    y: int = 2
    z: int = 3
    print(x < y < z)
