# Simple interface implementation test
interface IGreeter:
    def greet(self) -> int:
        ...

class FriendlyGreeter(IGreeter):
    value: int
    
    def __init__(self, v: int):
        self.value = v
    
    def greet(self) -> int:
        return self.value + 10

g: IGreeter = FriendlyGreeter(5)

def main():
    print(g.greet())

    # EXPECTED OUTPUT:
    # 15
