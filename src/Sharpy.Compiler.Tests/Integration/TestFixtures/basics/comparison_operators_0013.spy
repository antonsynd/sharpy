# Test comparison operators with int variables
a: int = 10
b: int = 20
c: int = 10

# Test equality and inequality
print(a == c)
print(a == b)
print(a != b)

# Test less than and greater than
print(a < b)
print(b > a)
print(a > b)

# Test less/greater than or equal
print(a <= c)
print(a >= c)
print(b <= a)

# EXPECTED OUTPUT:
# True
# False
# True
# True
# True
# False
# True
# True
# False