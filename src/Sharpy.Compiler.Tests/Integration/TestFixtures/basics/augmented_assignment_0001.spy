# Test augmented assignment with temperature tracking
current_temp: int = 20

def main():
    current_temp += 5
    print(current_temp)

    current_temp -= 3
    print(current_temp)

    current_temp *= 2
    print(current_temp)

    current_temp //= 4
    print(current_temp)

    current_temp %= 7
    print(current_temp)

    # EXPECTED OUTPUT:
    # 25
    # 22
    # 44
    # 11
    # 4
