# Complex boolean logic system with access control and state management

@abstract
class SecurityPolicy:
    enabled: bool

    def __init__(self, enabled: bool):
        self.enabled = enabled

    @abstract
    def evaluate(self, is_authenticated: bool, has_role: bool) -> bool:
        ...

class StrictPolicy(SecurityPolicy):
    require_both: bool

    def __init__(self, enabled: bool, require_both: bool):
        super().__init__(enabled)
        self.require_both = require_both

    @override
    def evaluate(self, is_authenticated: bool, has_role: bool) -> bool:
        if not self.enabled:
            return True
        if self.require_both:
            return is_authenticated and has_role
        return is_authenticated or has_role

class PermissivePolicy(SecurityPolicy):
    def __init__(self, enabled: bool):
        super().__init__(enabled)

    @override
    def evaluate(self, is_authenticated: bool, has_role: bool) -> bool:
        if not self.enabled:
            return True
        return is_authenticated or has_role

class AccessManager:
    policy: SecurityPolicy
    locked: bool
    admin_override: bool

    def __init__(self, policy: SecurityPolicy, locked: bool, admin_override: bool):
        self.policy = policy
        self.locked = locked
        self.admin_override = admin_override

    def check_access(self, is_authenticated: bool, has_role: bool, is_admin: bool) -> bool:
        if self.locked and not self.admin_override:
            return False
        if self.admin_override and is_admin:
            return True
        return self.policy.evaluate(is_authenticated, has_role)

    def toggle_lock(self) -> None:
        self.locked = not self.locked

def run_access_tests() -> None:
    strict: StrictPolicy = StrictPolicy(True, True)
    permissive: PermissivePolicy = PermissivePolicy(True)
    
    manager1: AccessManager = AccessManager(strict, False, True)
    manager2: AccessManager = AccessManager(permissive, True, False)
    
    print(manager1.check_access(True, True, False))
    print(manager1.check_access(True, False, False))
    print(manager1.check_access(False, False, True))
    
    print(manager2.check_access(True, False, False))
    
    manager2.toggle_lock()
    print(manager2.check_access(True, False, False))
    print(manager2.check_access(False, True, False))
    
    disabled_policy: StrictPolicy = StrictPolicy(False, True)
    manager3: AccessManager = AccessManager(disabled_policy, False, False)
    print(manager3.check_access(False, False, False))

run_access_tests()

# EXPECTED OUTPUT:
# True
# False
# True
# False
# True
# True
# True