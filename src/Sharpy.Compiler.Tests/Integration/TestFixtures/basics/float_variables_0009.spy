# Float variables: arithmetic, comparisons, and type handling

def compute_area(radius: float) -> float:
    pi: float = 3.14159
    return pi * radius * radius

def convert_temperature(celsius: float) -> float:
    # Convert Celsius to Fahrenheit
    factor: float = 1.8
    offset: float = 32.0
    return celsius * factor + offset

# Test basic float operations
x: float = 10.5
y: float = 3.2
sum_val: float = x + y
diff_val: float = x - y
prod_val: float = x * y
quot_val: float = x / y
circle_area: float = compute_area(2.0)
temp_f: float = convert_temperature(25.0)
threshold: float = 50.0
accumulator: float = 1.0

def main():
    print(x)
    print(y)

    # Arithmetic operations

    print(sum_val)
    print(diff_val)
    print(prod_val)
    print(quot_val)

    # Function calls with floats
    print(circle_area)

    print(temp_f)

    # Float comparisons with control flow
    if temp_f > threshold:
        print(True)
    else:
        print(False)

    # Augmented assignment with floats
    accumulator *= 2.5
    accumulator += 0.5
    print(accumulator)

    # EXPECTED OUTPUT:
    # 10.5
    # 3.2
    # 13.7
    # 7.3
    # 33.6
    # 3.28125
    # 12.56636
    # 77
    # True
    # 3
