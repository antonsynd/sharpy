# Test f-string float formatting for member access (self.x)
# Ensures float values print as 1.0, not 1

class Point:
    x: float
    y: float

    def __init__(self, x: float, y: float):
        self.x = x
        self.y = y

    def display(self):
        print(f"{self.x}")
        print(f"{self.y}")

def main():
    x: float = 1.0
    print(f"{x}")
    p: Point = Point(1.0, 2.5)
    p.display()
