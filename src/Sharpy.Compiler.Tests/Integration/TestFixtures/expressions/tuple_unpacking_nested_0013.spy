# Test: Nested tuple unpacking with abstract regions and polymorphism

@abstract
class Region:
    @abstract
    def get_bounds(self) -> tuple[tuple[int, int], tuple[int, int]]:
        ...

    @virtual
    def label(self) -> str:
        return "Region"

class Rectangle(Region):
    _x: int
    _y: int
    _w: int
    _h: int

    def __init__(self, x: int, y: int, w: int, h: int):
        self._x = x
        self._y = y
        self._w = w
        self._h = h

    @override
    def get_bounds(self) -> tuple[tuple[int, int], tuple[int, int]]:
        return ((self._x, self._y), (self._x + self._w, self._y + self._h))

    @override
    def label(self) -> str:
        return "Rectangle"

class Circle(Region):
    _cx: int
    _cy: int
    _r: int

    def __init__(self, cx: int, cy: int, r: int):
        self._cx = cx
        self._cy = cy
        self._r = r

    @override
    def get_bounds(self) -> tuple[tuple[int, int], tuple[int, int]]:
        return ((self._cx - self._r, self._cy - self._r), (self._cx + self._r, self._cy + self._r))

    @override
    def label(self) -> str:
        return "Circle"

def describe_bounds(region: Region) -> None:
    (min_x, min_y), (max_x, max_y) = region.get_bounds()
    w = max_x - min_x
    h = max_y - min_y
    print(f"{region.label()}: top-left=({min_x},{min_y}), size={w}x{h}")

def main():
    regions: list[Region] = [Rectangle(2, 3, 6, 4), Circle(5, 5, 3)]

    for region in regions:
        describe_bounds(region)

    pairs: list[tuple[int, int]] = [(1, 10), (2, 20), (3, 30)]
    first, *rest = pairs
    fx, fy = first
    print(f"First pair: {fx}, {fy}")
    print(f"Remaining: {len(rest)}")

    data: tuple[tuple[int, int], tuple[int, int]] = ((0, 0), (100, 200))
    (ox, oy), (ex, ey) = data
    print(f"Origin: {ox},{oy}")
    print(f"Extent: {ex},{ey}")

    i: int = 0
    for pt in rest:
        px, py = pt
        print(f"  rest[{i}]: ({px},{py})")
        i += 1

# EXPECTED OUTPUT:
# Rectangle: top-left=(2,3), size=6x4
# Circle: top-left=(2,2), size=6x6
# Remaining: 2
# Origin: 0,0
# Extent: 100,200
#   rest[0]: (2,20)
#   rest[1]: (3,30)