# Test: try/else with list variable (non-trivial reference type)
def main():
    data: list[int] = []
    count: int = 0
    try:
        data = [10, 20, 30]
        count = len(data)
    except Exception:
        print("error")
    else:
        print(count)
        for item in data:
            print(item)
