def f(x: int, y: int => x + 1) -> int:
    return x + y

def g(items: list[int], sep: str => ", ") -> str:
    result: str = ""
    for i, item in enumerate(items):
        if i > 0:
            result = result + sep
        result = result + str(item)
    return result

def main():
    # y provided explicitly
    print(f(10, 5))
    # y uses late-bound default (x + 1 = 3 + 1 = 4), so f(3) = 3 + 4 = 7
    print(f(3))
    # sep provided explicitly
    print(g([1, 2, 3], " | "))
    # sep uses late-bound default ", "
    print(g([1, 2, 3]))
