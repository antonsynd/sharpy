# Test that soft keywords (match, case, type) can be used as keyword argument
# names in function calls. Python 3.10+ treats match/case/type as soft keywords.

def greet(name: str, match: str = "hi") -> None:
    print(name)

def check(value: int, case: int = 0) -> None:
    print(value)

def describe(label: str, type: str = "unknown") -> None:
    print(label)

def combine(a: str, match: str = "", case: int = 0, type: str = "") -> None:
    print(a)

def main():
    greet("alice", match="hello")
    greet(name="bob", match="world")
    check(42, case=1)
    check(value=99, case=2)
    describe("item", type="widget")
    combine("test", match="pat", case=3, type="demo")
