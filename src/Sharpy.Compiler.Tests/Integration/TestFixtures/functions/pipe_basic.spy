def double(x: int) -> int:
    return x * 2

def add_one(x: int) -> int:
    return x + 1

def to_str(x: int) -> str:
    return str(x)

def main():
    # Basic pipe
    result: int = 5 |> double()
    print(result)

    # Chained pipes
    result2: str = 3 |> double() |> add_one() |> to_str()
    print(result2)

    # Pipe with additional arguments
    result3: int = 10 |> add_one()
    print(result3)
