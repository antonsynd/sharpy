def multiply(x: int, y: int) -> int:
    return x * y

def add(x: int, y: int) -> int:
    return x + y

def main():
    # Pipe with partial application
    result: int = 5 |> multiply(_, 3)
    print(result)

    result2: int = 10 |> add(_, 20)
    print(result2)

    # Chain
    result3: int = 5 |> multiply(_, 2) |> add(_, 100)
    print(result3)
