# Test decorator arguments on events

delegate MsgHandler(msg: str) -> None

class Publisher:
    @[obsolete("Use on_message instead")]
    event on_msg: MsgHandler

    def notify(self, msg: str):
        self.on_msg?.invoke(msg)

def handler(msg: str):
    print(msg)

def main():
    p: Publisher = Publisher()
    p.on_msg += handler
    p.notify("event with decorator works")
