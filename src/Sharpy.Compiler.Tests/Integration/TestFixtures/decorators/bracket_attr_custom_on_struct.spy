# Test: Custom attribute applied to a struct
from System import Attribute

class TagAttribute(Attribute):
    label: str

    def __init__(self, label: str):
        super().__init__()
        self.label = label

@[tag_attribute("point")]
struct Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

def main():
    p = Point(3, 4)
    print(p.x)
    print(p.y)
