# Test time.gmtime(secs) with Unix timestamp
import time

def main():
    # Unix epoch: 1970-01-01 00:00:00 UTC
    t = time.gmtime(0.0)
    print(t.tm_year)
    print(t.tm_mon)
    print(t.tm_mday)
    print(t.tm_hour)
    print(t.tm_min)
    print(t.tm_sec)
    print(t.tm_wday)
    print(t.tm_yday)

    # One day after epoch: 1970-01-02 00:00:00 UTC
    t2 = time.gmtime(86400.0)
    print(t2.tm_year)
    print(t2.tm_mon)
    print(t2.tm_mday)
