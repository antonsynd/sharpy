# Test: reversed() on user class - assign to variable and convert to list
class Countdown:
    limit: int
    def __init__(self, limit: int):
        self.limit = limit
    def __iter__(self) -> int:
        i: int = 1
        while i <= self.limit:
            yield i
            i += 1
    def __reversed__(self) -> int:
        i: int = self.limit
        while i >= 1:
            yield i
            i -= 1

def main():
    c = Countdown(3)
    rev = reversed(c)
    for x in rev:
        print(x)
    c2 = Countdown(4)
    items: list[int] = list(reversed(c2))
    print(items)
