# Test: reversed() on user-defined class with __reversed__()
class Countdown:
    limit: int
    def __init__(self, limit: int):
        self.limit = limit
    def __iter__(self) -> int:
        i: int = 1
        while i <= self.limit:
            yield i
            i += 1
    def __reversed__(self) -> int:
        i: int = self.limit
        while i >= 1:
            yield i
            i -= 1

def main():
    c = Countdown(5)
    for x in reversed(c):
        print(x)
