# Multi-iterable map() over two and three iterables, plus strict=True (#990)
def add(a: int, b: int) -> int:
    return a + b

def add3(a: int, b: int, c: int) -> int:
    return a + b + c

def main() -> None:
    a: list[int] = [1, 2, 3]
    b: list[int] = [10, 20, 30]
    c: list[int] = [100, 200, 300]
    two: list[int] = list(map(add, a, b))
    print(two)
    three: list[int] = list(map(add3, a, b, c))
    print(three)
    strict_two: list[int] = list(map(add, a, b, strict=True))
    print(strict_two)
