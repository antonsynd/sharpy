# #1012: a non-callable key= in the variadic value form of min()/max() must produce a clean
# Sharpy diagnostic (SPY0230), not a leaked C# error. BuiltinReturnTypeInference returns the
# value type before overload resolution, so ValidateMinMaxValueFormKey checks key callability.
def main() -> None:
    print(min(3, 1, 2, key=5))
