class Storage:
    _items: list[str]

    def __init__(self, items: list[str]):
        self._items = items

    def __getitem__(self, index: int) -> str:
        return self._items[index]

    def __setitem__(self, index: int, value: str):
        self._items[index] = value

def main():
    s: Storage = Storage(["a", "b", "c"])
    s[0] = "x"
    s[2] = "z"
    print(s[0])
    print(s[1])
    print(s[2])
