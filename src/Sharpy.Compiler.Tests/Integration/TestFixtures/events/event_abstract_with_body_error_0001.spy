# Abstract event with non-abstract body (SPY0423)
delegate MyHandler(sender: object, data: str) -> None

class Base:
    @abstract
    event add on_change(self, handler: MyHandler):
        print("not ellipsis")

    @abstract
    event remove on_change(self, handler: MyHandler):
        print("not ellipsis")

def main():
    print("unreachable")
