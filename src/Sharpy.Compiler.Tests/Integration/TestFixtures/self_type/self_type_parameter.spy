class Vector:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def add(self, other: Self) -> Self:
        return Vector(self.x + other.x, self.y + other.y)

    def __str__(self) -> str:
        return "(" + str(self.x) + ", " + str(self.y) + ")"

def main() -> None:
    a: Vector = Vector(1, 2)
    b: Vector = Vector(3, 4)
    c: Vector = a.add(b)
    print(c)
