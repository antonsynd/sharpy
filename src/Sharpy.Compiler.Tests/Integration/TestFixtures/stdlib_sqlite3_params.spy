# Test sqlite3 module: parameterized queries and rowcount
import sqlite3

def main():
    conn = sqlite3.connect(":memory:")
    cur = conn.cursor()
    cur.execute("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT, price REAL)")
    cur.execute("INSERT INTO items (name, price) VALUES ('apple', 1.5)")
    cur.execute("INSERT INTO items (name, price) VALUES ('banana', 0.75)")
    cur.execute("INSERT INTO items (name, price) VALUES ('cherry', 3.0)")
    conn.commit()
    print(cur.lastrowid)
    cur.execute("UPDATE items SET price = 2.0 WHERE name = 'banana'")
    conn.commit()
    print(cur.rowcount)
    cur.execute("SELECT name FROM items WHERE price > 1.0 ORDER BY name")
    rows = cur.fetchall()
    print(len(rows))
    cur.execute("DELETE FROM items WHERE name = 'cherry'")
    conn.commit()
    print(cur.rowcount)
    conn.close()
