# Test: Property inheritance with virtual/override and polymorphic access
# Switches to method-based to avoid @virtual/@override property syntax

class Shape:
    _name: str
    
    def __init__(self, name: str):
        self._name = name
    
    @virtual
    def get_description(self) -> str:
        return f"Shape: {self._name}"

class Rectangle(Shape):
    width: float
    height: float
    
    def __init__(self, name: str, w: float, h: float):
        super().__init__(name)
        self.width = w
        self.height = h
    
    @override
    def get_description(self) -> str:
        area: float = self.width * self.height
        return f"Rectangle '{self._name}': {self.width}x{self.height} (area={area})"

class Circle(Shape):
    radius: float
    
    def __init__(self, name: str, r: float):
        super().__init__(name)
        self.radius = r
    
    @override
    def get_description(self) -> str:
        area: float = 3.14159 * self.radius ** 2
        return f"Circle '{self._name}': r={self.radius} (area={area:.2f})"

def show_shape(s: Shape) -> None:
    print(s.get_description())

def main():
    shapes: list[Shape] = []
    shapes.append(Rectangle("box", 5.0, 3.0))
    shapes.append(Circle("wheel", 2.0))
    shapes.append(Shape("generic"))
    
    i: int = 0
    while i < len(shapes):
        s: Shape = shapes[i]
        show_shape(s)
        i = i + 1
