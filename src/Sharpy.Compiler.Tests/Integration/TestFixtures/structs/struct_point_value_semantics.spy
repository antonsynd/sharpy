# Test struct definition with value semantics (copy on assignment)

struct Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def move(self, dx: int, dy: int) -> None:
        self.x += dx
        self.y += dy

p1 = Point(10, 20)
p2 = p1
p2.move(5, 5)

print(p1.x)
print(p1.y)
print(p2.x)
print(p2.y)
