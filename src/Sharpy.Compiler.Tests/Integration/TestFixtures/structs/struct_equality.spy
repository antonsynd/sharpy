# Test struct equality with __eq__ and __hash__
struct Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __eq__(self, other: object) -> bool:
        if isinstance(other, Point):
            p: Point = other
            return self.x == p.x and self.y == p.y
        return False

    def __hash__(self) -> int:
        return self.x * 31 + self.y

def main():
    p1: Point = Point(1, 2)
    p2: Point = Point(1, 2)
    p3: Point = Point(3, 4)
    print(p1 == p2)
    print(p1 == p3)
    print(p1 != p3)
