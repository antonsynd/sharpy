struct Point:
    @final
    x: int

    @final
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __init__(self, value: int):
        self.x = value
        self.y = value

    def describe(self) -> str:
        return f"({self.x}, {self.y})"

def main():
    p: Point = Point(1, 2)
    print(p.describe())
    q: Point = Point(5)
    print(q.describe())
