# Test struct implementing interface with polymorphic dispatch
interface IDescribable:
    def describe(self) -> str:
        ...

struct Point(IDescribable):
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def describe(self) -> str:
        return f"Point({self.x}, {self.y})"

def print_description(d: IDescribable) -> None:
    print(d.describe())

def main():
    p: Point = Point(3, 4)
    print(p.describe())
    print_description(p)
