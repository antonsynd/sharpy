# Test: struct with __str__ override (no @virtual decorator) works correctly
struct Point:
    x: int
    y: int
    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y
    def __str__(self) -> str:
        return f"Point({self.x}, {self.y})"

def main():
    p = Point(3, 4)
    print(p)
    print(str(p))
