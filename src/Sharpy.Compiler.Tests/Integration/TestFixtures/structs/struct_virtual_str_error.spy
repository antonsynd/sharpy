# Test: @virtual on struct method should error (structs are sealed)
struct Point:
    x: int
    y: int
    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y
    @virtual
    def __str__(self) -> str:
        return f"({self.x}, {self.y})"

def main():
    p = Point(1, 2)
    print(p)
