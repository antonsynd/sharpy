def main():
    result: int !ValueError = int.parse("42")
    if result.is_ok:
        print(result.unwrap())
    else:
        print(result.unwrap_err())

    result2: int !ValueError = int.parse("abc")
    if result2.is_ok:
        print(result2.unwrap())
    else:
        print(result2.unwrap_err())
