def main():
    matrix: list[list[int]] = [
        [1, 2, 3],
        [4, 5, 6],
        [7, 8, 9]
    ]
    print(len(matrix))
    print(matrix[0][0])
    print(matrix[1][1])
    print(matrix[2][2])

    pairs: list[tuple[int, str]] = [
        (1, "one"),
        (2, "two"),
        (3, "three")
    ]
    for p in pairs:
        print(p[1])
