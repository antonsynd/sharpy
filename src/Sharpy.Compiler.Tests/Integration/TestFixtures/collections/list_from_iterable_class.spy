# Test: list() infers element type from various iterable sources

def main():
    # list from another list
    source: list[int] = [3, 1, 2]
    copy: list[int] = list(source)
    print(copy[0])
    print(copy[1])
    print(copy[2])

    # Verify the inferred type is int by doing arithmetic
    total: int = copy[0] + copy[1] + copy[2]
    print(total)
