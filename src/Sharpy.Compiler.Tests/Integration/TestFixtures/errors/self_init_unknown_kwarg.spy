# Issue #907: an unknown keyword argument passed to self.__init__() (constructor
# delegation across overloads) must be rejected at the semantic stage (SPY0234)
# instead of leaking to a CS1739 error from the generated C#.
class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

    def __init__(self, x: int):
        self.__init__(bogus=1)


def main():
    p: Point = Point(5)
    print(p.x)
