class Foo:
    value: int

    def __init__(self, value: int):
        self.value = value

    def __eq__(self, other: object) -> bool:
        if not isinstance(other, Foo):
            return False
        return self.value == other.value

    def __hash__(self) -> int:
        return self.value

    def compare(self, other: Foo) -> bool:
        return self.__eq__(other)

def main():
    f: Foo = Foo(1)
    g: Foo = Foo(2)
    print(f.compare(g))
