# Test json.dumps with dict[str, ...] keys
import json

def main():
    # Simple dict with str keys
    d: dict[str, int] = {"a": 1, "b": 2}
    print(json.dumps(d))

    # Nested dict with str keys
    inner: dict[str, int] = {"x": 10}
    outer: dict[str, object] = {"inner": inner, "name": "test"}
    print(json.dumps(outer))
