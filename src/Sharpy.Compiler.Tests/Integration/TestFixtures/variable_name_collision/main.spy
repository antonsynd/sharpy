# Test: Variable name collision between user-declared and generated names
# When a variable is redeclared with a type annotation, the emitter generates
# versioned names (x_1, x_2). This test ensures that user-declared x_1 (mangled
# to x1) does not conflict with the generated versioned name x_1.

def main():
    x: int = 1           # First declaration: x
    x_1: str = "user"    # User declares x_1 (mangled to x1)
    x: int = 2           # Redeclaration: generates x_1 (no collision with x1)
    print(x)             # Should print 2 (current version of x)
    print(x_1)           # Should print "user"
