def gcd(a: int, b: int) -> int:
    if b == 0:
        return a
    return gcd(b, a % b)

def lcm(a: int, b: int) -> int:
    return (a * b) // gcd(a, b)

def main():
    print(f"gcd(48, 18) = {gcd(48, 18)}")
    print(f"gcd(100, 75) = {gcd(100, 75)}")
    print(f"lcm(4, 6) = {lcm(4, 6)}")
    print(f"lcm(12, 18) = {lcm(12, 18)}")
