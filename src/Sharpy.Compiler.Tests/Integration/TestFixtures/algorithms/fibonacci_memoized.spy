def fib(n: int, cache: dict[int, int]) -> int:
    if n in cache:
        return cache[n]
    if n <= 1:
        return n
    result: int = fib(n - 1, cache) + fib(n - 2, cache)
    cache[n] = result
    return result

def main():
    cache: dict[int, int] = {}
    print(f"fib(0) = {fib(0, cache)}")
    print(f"fib(1) = {fib(1, cache)}")
    print(f"fib(10) = {fib(10, cache)}")
    print(f"fib(20) = {fib(20, cache)}")
    print(f"fib(30) = {fib(30, cache)}")
