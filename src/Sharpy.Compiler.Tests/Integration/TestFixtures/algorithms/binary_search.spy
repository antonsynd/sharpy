def search(arr: list[int], target: int) -> int:
    lo: int = 0
    hi: int = len(arr) - 1
    while lo <= hi:
        mid: int = (lo + hi) // 2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            lo = mid + 1
        else:
            hi = mid - 1
    return -1

def main():
    arr: list[int] = [1, 3, 5, 7, 9, 11, 13, 15]
    idx: int = search(arr, 7)
    print(f"Found 7 at index {idx}")
    idx = search(arr, 1)
    print(f"Found 1 at index {idx}")
    idx = search(arr, 10)
    if idx == -1:
        print("10 not found")
