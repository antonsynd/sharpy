def sort(arr: list[int]) -> list[int]:
    n: int = len(arr)
    i: int = 1
    while i < n:
        key: int = arr[i]
        j: int = i - 1
        while j >= 0 and arr[j] > key:
            arr[j + 1] = arr[j]
            j -= 1
        arr[j + 1] = key
        i += 1
    return arr

def main():
    nums: list[int] = [12, 11, 13, 5, 6]
    result: list[int] = sort(nums)
    print(result)
