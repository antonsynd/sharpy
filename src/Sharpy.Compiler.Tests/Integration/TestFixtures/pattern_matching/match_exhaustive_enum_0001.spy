enum Color:
    RED = 0
    GREEN = 1
    BLUE = 2

def describe(c: Color) -> str:
    match c:
        case Color.RED:
            return "red"
        case Color.GREEN:
            return "green"
        case Color.BLUE:
            return "blue"
    return ""

def main():
    print(describe(Color.RED))
    print(describe(Color.GREEN))
    print(describe(Color.BLUE))
