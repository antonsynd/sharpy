# Match an `object` parameter against a bare `case dict()` collection pattern.
# Semantic layer infers dict[object, object]; codegen lowers to Sharpy.IDict (#869).
# Verifies dispatch + len() — the original regression guard.

def process(value: object) -> None:
    match value:
        case dict() as d:
            print("dict with " + str(len(d)) + " entries")
        case _:
            print("not a dict")

def main():
    process({"a": 1, "b": 2})
    process(42)
