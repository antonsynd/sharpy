def classify(x: int) -> str:
    match x:
        case 1 | 2 | 3:
            return "small"
        case 4 | 5:
            return "medium"
        case _:
            return "large"

def main():
    print(classify(1))
    print(classify(2))
    print(classify(3))
    print(classify(4))
    print(classify(5))
    print(classify(100))
