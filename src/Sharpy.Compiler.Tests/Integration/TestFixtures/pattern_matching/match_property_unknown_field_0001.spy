class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

def describe(p: Point) -> str:
    match p:
        case Point(z=0):
            return "z is zero"
        case _:
            return "other"

def main():
    print(describe(Point(0, 0)))
