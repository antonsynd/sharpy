@abstract
class GamePlayer:
    name: str

    def __init__(self, name: str):
        self.name = name

    @abstract
    def base_score(self) -> int: ...

    @abstract
    def player_type(self) -> str: ...

    @virtual
    def bonus_for_round(self, round_num: int) -> int:
        return self.base_score() // 2

    def score_for_rounds(self, num_rounds: int) -> int:
        total: int = 0
        for r in range(1, num_rounds + 1):
            total += self.base_score() + self.bonus_for_round(r)
        return total


class Warrior(GamePlayer):
    strength: int

    def __init__(self, name: str, strength: int):
        super().__init__(name)
        self.strength = strength

    @override
    def base_score(self) -> int:
        return self.strength * 10

    @override
    def player_type(self) -> str:
        return "Warrior"

    @override
    def bonus_for_round(self, round_num: int) -> int:
        return self.strength * round_num


class Mage(GamePlayer):
    spell_power: int

    def __init__(self, name: str, spell_power: int):
        super().__init__(name)
        self.spell_power = spell_power

    @override
    def base_score(self) -> int:
        return self.spell_power * 8

    @override
    def player_type(self) -> str:
        return "Mage"


def main():
    players: list[GamePlayer] = []
    players.append(Warrior("Thorin", 5))
    players.append(Mage("Gandalf", 7))
    players.append(Warrior("Aragorn", 6))

    rounds: int = 3

    for player in players:
        score = player.score_for_rounds(rounds)
        print(f"{player.name} ({player.player_type()}): base={player.base_score()}, total={score}")

    best: GamePlayer = players[0]
    best_score: int = best.score_for_rounds(rounds)
    for player in players:
        s = player.score_for_rounds(rounds)
        if s > best_score:
            best = player
            best_score = s

    print(f"Winner: {best.name}")
    print(f"Type: {best.player_type()}")
    print(f"Score: {best_score}")

# EXPECTED OUTPUT:
# Thorin (Warrior): base=50, total=180
# Gandalf (Mage): base=56, total=252
# Aragorn (Warrior): base=60, total=216
# Winner: Gandalf
# Type: Mage
# Score: 252