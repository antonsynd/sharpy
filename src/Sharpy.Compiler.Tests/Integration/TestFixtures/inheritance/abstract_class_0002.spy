# Abstract class with abstract method
@abstract
class Shape:
    @abstract
    def area(self) -> int:
        ...

# Concrete implementation
class Square(Shape):
    side: int

    def __init__(self, s: int):
        self.side = s

    @override
    def area(self) -> int:
        return self.side * self.side

sq = Square(5)
print(sq.area())

# EXPECTED OUTPUT:
# 25