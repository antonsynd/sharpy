# Test super().__init__() with simple field initialization

class Animal:
    name: str
    
    def __init__(self, name: str):
        self.name = name

class Dog(Animal):
    age: int
    
    def __init__(self, name: str, age: int):
        super().__init__(name)
        self.age = age
    
    def get_age(self) -> int:
        return self.age

d = Dog("Buddy", 3)
print(d.get_age())

# EXPECTED OUTPUT:
# 3