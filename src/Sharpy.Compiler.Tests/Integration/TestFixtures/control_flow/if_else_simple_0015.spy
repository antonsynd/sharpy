def main():
    value: int = -7
    result: int = 0

    if value < 0:
        result = value * -1
    else:
        result = value * 2

    print(result)

    threshold: int = 10
    adjusted: int = 0

    if threshold >= 10:
        adjusted = threshold // 2
    else:
        adjusted = threshold * 3

    print(adjusted)
# EXPECTED OUTPUT:
# 7
# 5