# Test: Nested if statements inside a for loop
# Uses: range, if/elif/else, comparison operators, arithmetic
def main():
    for i in range(-4, 5):
        if i < 0:
            if i % 3 == 0:
                print("neg_mult_3")
            else:
                print("negative")
        elif i == 0:
            print("zero")
        else:
            if i % 2 == 0:
                print("pos_even")
            else:
                print("positive")
