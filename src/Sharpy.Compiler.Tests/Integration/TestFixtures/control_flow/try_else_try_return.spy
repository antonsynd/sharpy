def process(x: int) -> str:
    val: int = 0
    try:
        val = x
    except Exception:
        return "outer error"
    else:
        result: int = 0
        try:
            result = val * 2
        except Exception:
            return "inner error"
        else:
            return str(result)

def main():
    print(process(5))
    print(process(0))
    print(process(-3))
