# Test json.dumps with default callback
import json

class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y

def point_to_dict(obj: object) -> object:
    if isinstance(obj, Point):
        return {"x": obj.x, "y": obj.y}
    raise TypeError("Object is not JSON serializable")

def main():
    p = Point(1, 2)
    print(json.dumps(p, default=point_to_dict))
