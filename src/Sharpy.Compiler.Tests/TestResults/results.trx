        else if (x &lt; 0)&#xD;
        {&#xD;
            global::Sharpy.Core.Exports.Print("negative");&#xD;
        }&#xD;
        else&#xD;
        {&#xD;
            global::Sharpy.Core.Exports.Print("zero");&#xD;
        }&#xD;
    }&#xD;
&#xD;
    public static void Main()&#xD;
    {&#xD;
        ClassifyNumber(5);&#xD;
        ClassifyNumber(-3);&#xD;
        ClassifyNumber(0);&#xD;
    }&#xD;
}
