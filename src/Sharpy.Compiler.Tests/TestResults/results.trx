        int j = 10;&#xD;
        while (i &lt; 5)&#xD;
        {&#xD;
            i = i + 1;&#xD;
            j = j - 1;&#xD;
            global::Sharpy.Core.Exports.Print(i);&#xD;
            global::Sharpy.Core.Exports.Print(j);&#xD;
        }&#xD;
    }&#xD;
}
