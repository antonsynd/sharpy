from unittest import captured_output

# Exercises the captured_output runtime path under CompileAndExecute (which runs
# main(), not xUnit): redirect, getvalue(), and restore must all work for real.
def main():
    captured: str = ""
    with captured_output() as output:
        print("hello")
        print("world")
        captured = output.getvalue()
    # Console.Out is restored here; these prints reach real stdout.
    if captured == "hello\nworld\n":
        print("capture-ok")
    else:
        print("capture-FAIL")
    print("stdout-restored")
