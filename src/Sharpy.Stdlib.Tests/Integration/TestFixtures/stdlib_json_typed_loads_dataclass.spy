# Test json.loads[T] with a @dataclass type
import json

@dataclass
class User:
    name: str
    age: int

def main():
    text: str = '{"name": "Alice", "age": 30}'
    result = json.loads[User](text)
    if result.is_ok:
        u = result.unwrap()
        print(u.name)
        print(u.age)
    else:
        print("ERROR")
