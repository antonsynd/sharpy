import secrets

def main():
    # token_hex length: 16 bytes = 32 hex chars
    h = secrets.token_hex(16)
    print(len(h))

    # randbelow bounds
    r = secrets.randbelow(10)
    print(r >= 0 and r < 10)

    # randbelow(1) always returns 0
    print(secrets.randbelow(1))

    # compare_digest matching
    print(secrets.compare_digest("abc", "abc"))

    # compare_digest non-matching
    print(secrets.compare_digest("abc", "xyz"))
