# Verify that numpy.fft.fft returns a properly-typed NdArray (NdArray<Complex>,
# not NdArray<object>) after ClrTypeMapper gains NdArray mapping (#968).
from numpy.fft import fft, fftfreq
import numpy as np

def main():
    arr = np.array([1.0, 2.0, 3.0, 4.0])
    result = fft(arr)
    print(result.size)

    freqs = fftfreq(4, 1.0)
    print(freqs.size)
    print(freqs[0])
