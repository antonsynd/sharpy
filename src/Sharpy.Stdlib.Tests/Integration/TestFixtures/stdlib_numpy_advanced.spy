# Test advanced numpy features: sort, unique, allclose, isnan/isinf/isfinite.
import numpy as np

def main():
    # arange returns a 1-D ascending sequence.
    seq = np.arange(0.0, 5.0)
    print(seq)

    # allclose with itself is true.
    print(np.allclose(seq, seq))

    # sort produces a sorted copy.
    unsorted = np.array([3.0, 1.0, 4.0, 1.0, 5.0])
    print(np.sort(unsorted))

    # unique returns sorted distinct elements.
    dup = np.array([3.0, 1.0, 2.0, 1.0, 3.0])
    print(np.unique(dup))
