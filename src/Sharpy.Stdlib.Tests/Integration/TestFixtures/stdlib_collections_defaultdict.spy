# Test collections.defaultdict
from collections import defaultdict

def main():
    # Construction with list factory
    d: defaultdict[str, list[int]] = defaultdict(list)
    d["a"].append(1)
    d["a"].append(2)
    d["b"].append(3)
    print(d["a"])
    print(d["b"])

    # Missing key creates default
    print(d["c"])

    # ContainsKey
    print("a" in d)
    print("z" in d)

    # Keys/Values
    print(sorted(list(d.keys())))

    # Pop
    val: list[int] = d.pop("a")
    print(val)
    print("a" in d)

    # Items
    print(len(d.items()))

    # Copy
    d2: defaultdict[str, list[int]] = d.copy()
    print(sorted(list(d2.keys())))

    # Clear
    d.clear()
    print(len(d.keys()))
