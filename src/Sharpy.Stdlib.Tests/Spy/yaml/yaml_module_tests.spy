from unittest import assert_raises, approx

import yaml
import operator

# Ported from YamlModuleTests.cs (#843).
# Untyped yaml.safe_load() returns object?; scalar results are compared with
# operator.eq (object '==' is rejected by Axiom 3) and structural results are
# navigated via match type-patterns (see json port / #912 for the indexing idiom).
#
# Omitted (documented in PORTING.md): the 5 null-argument TypeError guards
# (SafeLoad/SafeLoadAll/SafeLoadFile/SafeDumpFile/SafeDumpAll with null) cannot be
# expressed — passing None to a non-nullable str/list/TextFile parameter is a
# compile-time error in Sharpy (Axiom 3), so the runtime guard is unreachable from
# type-safe spy (same rationale as shlex/http null omissions).

# --- SafeLoad / SafeDump round-trip ---

@test
def test_round_trip_simple_mapping_preserves_data():
    data: dict[str, object] = {}
    data["name"] = "test"
    data["count"] = 42
    text: str = yaml.safe_dump(data)
    parsed: object = yaml.safe_load(text)
    match parsed:
        case dict() as result:
            assert operator.eq(result["name"], "test")
            assert operator.eq(result["count"], 42)
        case _:
            assert False

@test
def test_round_trip_list_preserves_data():
    data: list[object] = []
    data.append(1)
    data.append("two")
    data.append(True)
    data.append(None)
    text: str = yaml.safe_dump(data)
    parsed: object = yaml.safe_load(text)
    match parsed:
        case list() as result:
            assert operator.eq(result[0], 1)
            assert operator.eq(result[1], "two")
            assert operator.eq(result[2], True)
            assert result[3] is None
        case _:
            assert False

# --- SafeLoad - Scalar types ---

@test
def test_safe_load_string_returns_string():
    result: object = yaml.safe_load("key: hello")
    match result:
        case dict() as d:
            assert operator.eq(d["key"], "hello")
        case _:
            assert False

@test
def test_safe_load_quoted_string_returns_string():
    result: object = yaml.safe_load("key: \"hello world\"")
    match result:
        case dict() as d:
            assert operator.eq(d["key"], "hello world")
        case _:
            assert False

@test
def test_safe_load_int_returns_int():
    result: object = yaml.safe_load("key: 42")
    match result:
        case dict() as d:
            assert isinstance(d["key"], int)
            assert operator.eq(d["key"], 42)
        case _:
            assert False

@test
def test_safe_load_negative_int_returns_int():
    result: object = yaml.safe_load("key: -7")
    match result:
        case dict() as d:
            assert operator.eq(d["key"], -7)
        case _:
            assert False

@test
def test_safe_load_large_int_returns_long():
    result: object = yaml.safe_load("key: 9999999999")
    match result:
        case dict() as d:
            assert isinstance(d["key"], long)
            value: long = 9999999999
            assert operator.eq(d["key"], value)
        case _:
            assert False

@test
def test_safe_load_float_returns_double():
    # KNOWN QUIRK (see C# original): SafeLoad parses plain floats as single
    # precision and widens, so "3.14" reloads as ~3.1400001 — assert within
    # float precision rather than exact equality.
    result: object = yaml.safe_load("key: 3.14")
    match result:
        case dict() as d:
            assert isinstance(d["key"], float)
            match d["key"]:
                case float() as fv:
                    assert fv == approx(3.14, abs=1e-4)
                case _:
                    assert False
        case _:
            assert False

@test
def test_safe_load_whole_number_float_stays_float_typed():
    result: object = yaml.safe_load("key: 2.0")
    match result:
        case dict() as d:
            assert isinstance(d["key"], float)
            match d["key"]:
                case float() as fv:
                    assert fv == approx(2.0, abs=1e-4)
                case _:
                    assert False
        case _:
            assert False

@test
def test_safe_load_bool_true_returns_bool():
    result: object = yaml.safe_load("key: true")
    match result:
        case dict() as d:
            assert isinstance(d["key"], bool)
            assert operator.eq(d["key"], True)
        case _:
            assert False

@test
def test_safe_load_bool_false_returns_bool():
    result: object = yaml.safe_load("key: false")
    match result:
        case dict() as d:
            assert operator.eq(d["key"], False)
        case _:
            assert False

@test
def test_safe_load_null_returns_null():
    result: object = yaml.safe_load("key: null")
    match result:
        case dict() as d:
            assert d["key"] is None
        case _:
            assert False

@test
def test_safe_load_tilde_returns_null():
    result: object = yaml.safe_load("key: ~")
    match result:
        case dict() as d:
            assert d["key"] is None
        case _:
            assert False

# --- SafeLoad - Norway problem (YAML 1.2 core schema) ---
# Only true/false (case-insensitive) are booleans; no/yes/on/off/Y/N stay strings.

@test
def test_safe_load_norway_no_caps_stays_string():
    result: object = yaml.safe_load("key: NO")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "NO")
        case _:
            assert False

@test
def test_safe_load_norway_no_lower_stays_string():
    result: object = yaml.safe_load("key: no")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "no")
        case _:
            assert False

@test
def test_safe_load_norway_no_title_stays_string():
    result: object = yaml.safe_load("key: No")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "No")
        case _:
            assert False

@test
def test_safe_load_norway_yes_title_stays_string():
    result: object = yaml.safe_load("key: Yes")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "Yes")
        case _:
            assert False

@test
def test_safe_load_norway_yes_lower_stays_string():
    result: object = yaml.safe_load("key: yes")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "yes")
        case _:
            assert False

@test
def test_safe_load_norway_on_lower_stays_string():
    result: object = yaml.safe_load("key: on")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "on")
        case _:
            assert False

@test
def test_safe_load_norway_on_title_stays_string():
    result: object = yaml.safe_load("key: On")
    match result:
        case dict() as d:
            assert isinstance(d["key"], str)
            assert operator.eq(d["key"], "On")
