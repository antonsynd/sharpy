<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <RootNamespace>Sharpy.Stdlib.Tests.Spy</RootNamespace>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Sharpy.Stdlib.Tests.Spy</AssemblyName>
    <NoWarn>SPY0451,SPY0452,SPY0453</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Re-enabled by #886-#892 (plan f40f84): calendar, uuid, http, fractions, pprint, heapq,
         hmac, ipaddress, difflib, html. zoneinfo re-enabled by #901 (plan f8a99f).
         Still blocked by out-of-scope gaps (see PORTING.md residuals):
           email     — isinstance with a module-qualified type emits the type as a value, CS0119 (#903)
           functools — cmp_to_key generic free-function lambda inference fails, CS0411 (#904) -->
    <SourceFile Include="**/*.spy" Exclude="email/**;functools/functools_tests.spy" />
  </ItemGroup>
</Project>
