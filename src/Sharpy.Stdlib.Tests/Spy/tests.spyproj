<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <RootNamespace>Sharpy.Stdlib.Tests.Spy</RootNamespace>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Sharpy.Stdlib.Tests.Spy</AssemblyName>
    <NoWarn>SPY0451,SPY0452,SPY0453</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Temporarily excluded modules blocked by compiler limitations — see PORTING.md residuals -->
    <SourceFile Include="**/*.spy" Exclude="argparse/**;calendar/**;difflib/**;email/**;fractions/**;functools/functools_tests.spy;heapq/heapq_tests.spy;hmac/**;html/**;http/**;ipaddress/**;pprint/**;shlex/**;uuid/**;zoneinfo/**" />
  </ItemGroup>
</Project>
