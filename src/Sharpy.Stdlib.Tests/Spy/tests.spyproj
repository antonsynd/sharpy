<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <RootNamespace>Sharpy.Stdlib.Tests.Spy</RootNamespace>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Sharpy.Stdlib.Tests.Spy</AssemblyName>
    <NoWarn>SPY0451,SPY0452,SPY0453</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Re-enabled by #886-#892 (plan f40f84): calendar, uuid, http, fractions, pprint, heapq,
         hmac, ipaddress, difflib, html. zoneinfo (#901) + functools (#904) + email (#903)
         re-enabled by plan f8a99f. All previously-excluded modules now compile. -->
    <SourceFile Include="**/*.spy" />
  </ItemGroup>
</Project>
