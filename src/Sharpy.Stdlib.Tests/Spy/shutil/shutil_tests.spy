from unittest import assert_raises

import os
import shutil
from os.path import isdir, isfile, exists

# Ported from ShutilTests.cs (#843).
# The C# fixture creates a fresh temp dir per test in its constructor; here each
# test takes the pytest-style `tmp_path: str` fixture (#842) as its workspace.
# Paths are built with "/" concatenation (POSIX runners; shutil/_ResolveDestination
# use Path.Combine, equivalent on these runners), mirroring the glob port. Files are
# created via `with open(...)`; distinct `with` variable names are used per block
# (reusing one name across sequential `with` blocks breaks codegen, CS0103).
#
# Copy2_PreservesTimestamps: the C# set a custom mtime via File.SetLastWriteTimeUtc;
# os.utime is not exposed in Sharpy, so timestamp preservation is verified by
# comparing the destination mtime (os.stat().st_mtime) against the source mtime —
# copy2 copies the source mtime, whereas copy() would stamp "now".


# ===== copy =====

@test
def test_copy_copies_to_file(tmp_path: str):
    src = tmp_path + "/src.txt"
    with open(src, "w") as fa:
        fa.write("hello")
    dst = tmp_path + "/dst.txt"
    result = shutil.copy(src, dst)
    assert isfile(dst)
    content = ""
    with open(dst, "r") as fb:
        content = fb.read()
    assert content == "hello"
    assert result == dst


@test
def test_copy_copies_to_directory(tmp_path: str):
    src = tmp_path + "/src.txt"
    with open(src, "w") as fa:
        fa.write("hello")
    destdir = tmp_path + "/destdir"
    os.makedirs(destdir, existOk=True)
    result = shutil.copy(src, destdir)
    expected = destdir + "/src.txt"
    assert isfile(expected)
    assert result == expected


@test
def test_copy_throws_on_nonexistent_source(tmp_path: str):
    with assert_raises(OSError):
        shutil.copy(tmp_path + "/nope.txt", tmp_path + "/dst.txt")


# ===== copy2 =====

@test
def test_copy2_preserves_timestamps(tmp_path: str):
    src = tmp_path + "/src2.txt"
    with open(src, "w") as fa:
        fa.write("data")
    src_mtime: float = os.stat(src).st_mtime
    result = shutil.copy2(src, tmp_path + "/dst2.txt")
    assert os.stat(result).st_mtime == src_mtime


# ===== copytree =====

@test
def test_copytree_copies_recursively(tmp_path: str):
    src_dir = tmp_path + "/treesrc"
    os.makedirs(src_dir + "/sub", existOk=True)
    with open(src_dir + "/a.txt", "w") as fa:
        fa.write("a")
    with open(src_dir + "/sub/b.txt", "w") as fb:
        fb.write("b")
    dst_dir = tmp_path + "/treedst"
    result = shutil.copytree(src_dir, dst_dir)
    assert result == dst_dir
    assert isfile(dst_dir + "/a.txt")
    assert isfile(dst_dir + "/sub/b.txt")
    content = ""
    with open(dst_dir + "/sub/b.txt", "r") as fc:
        content = fc.read()
    assert content == "b"


@test
def test_copytree_throws_on_nonexistent_source(tmp_path: str):
    with assert_raises(OSError):
        shutil.copytree(tmp_path + "/nope", tmp_path + "/dst")


# ===== rmtree =====

@test
def test_rmtree_deletes_directory_tree(tmp_path: str):
    d = tmp_path + "/rmdir"
    os.makedirs(d + "/sub", existOk=True)
    with open(d + "/file.txt", "w") as fa:
        fa.write("data")
    with open(d + "/sub/inner.txt", "w") as fb:
        fb.write("inner")
    shutil.rmtree(d)
    assert not isdir(d)


@test
def test_rmtree_throws_on_nonexistent(tmp_path: str):
    with assert_raises(OSError):
        shutil.rmtree(tmp_path + "/nope")


# ===== move =====

@test
def test_move_moves_file(tmp_path: str):
    src = tmp_path + "/movesrc.txt"
    with open(src, "w") as fa:
        fa.write("move")
    dst = tmp_path + "/movedst.txt"
    result = shutil.move(src, dst)
    assert not exists(src)
    assert isfile(dst)
    content = ""
    with open(dst, "r") as fb:
        content = fb.read()
    assert content == "move"
    assert result == dst


@test
def test_move_moves_directory(tmp_path: str):
    src_dir = tmp_path + "/movedirsrc"
    os.makedirs(src_dir, existOk=True)
    with open(src_dir + "/f.txt", "w") as fa:
        fa.write("f")
    dst_dir = tmp_path + "/movedirdst"
    result = shutil.move(src_dir, dst_dir)
    assert not isdir(src_dir)
    assert isdir(dst_dir)
    assert isfile(dst_dir + "/f.txt")
    assert result == dst_dir


@test
def test_move_throws_on_nonexistent_source(tmp_path: str):
    with assert_raises(OSError):
        shutil.move(tmp_path + "/nope.txt", tmp_path + "/dst.txt")


# ===== which =====

@test
def test_which_finds_dotnet():
    result = shutil.which("dotnet")
    assert result is not None
    if result is not None:
        assert isfile(result)


@test
def test_which_returns_null_for_nonexistent():
    assert shutil.which("this_command_does_not_exist_xyz_123") is None


@test
def test_which_returns_null_for_empty():
    assert shutil.which("") is None


# ===== disk_usage =====

@test
def test_disk_usage_returns_sensible_values(tmp_path: str):
    total, used, free = shutil.disk_usage(tmp_path)
    assert total > 0
    assert used >= 0
    assert free >= 0
    assert used + free == total
