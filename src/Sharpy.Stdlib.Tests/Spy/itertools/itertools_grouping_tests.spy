# Literal arguments are bound to typed locals to avoid #917 (inline collection
# literals passed to a generic call mis-infer their element type from the outer
# result annotation, producing invalid C# / spurious SPY0222 with no reliable
# diagnostic).
import itertools

# --- Groupby ---

@test
def test_groupby_empty_iterable_returns_empty():
    empty: list[int] = []
    groups: list[tuple[int, list[int]]] = []
    for key, group in itertools.groupby(empty, lambda x: int: x):
        items: list[int] = []
        for item in group:
            items.append(item)
        groups.append((key, items))
    assert len(groups) == 0

@test
def test_groupby_non_consecutive_same_keys_creates_separate_groups():
    data: list[int] = [1, 2, 1, 2]
    groups: list[tuple[int, list[int]]] = []
    for key, group in itertools.groupby(data, lambda x: int: x):
        items: list[int] = []
        for item in group:
            items.append(item)
        groups.append((key, items))
    assert len(groups) == 4
    assert groups[0][0] == 1
    assert groups[1][0] == 2
    assert groups[2][0] == 1
    assert groups[3][0] == 2

@test
def test_groupby_by_string_length_groups_strings_correctly():
    data: list[str] = ["a", "ab", "b", "bc"]
    groups: list[tuple[int, list[str]]] = []
    for key, group in itertools.groupby(data, lambda s: str: len(s)):
        items: list[str] = []
        for item in group:
            items.append(item)
        groups.append((key, items))
    assert len(groups) == 4
    assert groups[0][0] == 1
    assert groups[0][1] == ["a"]
    assert groups[1][0] == 2
    assert groups[1][1] == ["ab"]
    assert groups[2][0] == 1
    assert groups[2][1] == ["b"]
    assert groups[3][0] == 2
    assert groups[3][1] == ["bc"]

@test
def test_groupby_all_same_key_returns_single_group():
    data: list[int] = [5, 5, 5]
    groups: list[tuple[int, list[int]]] = []
    for key, group in itertools.groupby(data, lambda x: int: x):
        items: list[int] = []
        for item in group:
            items.append(item)
        groups.append((key, items))
    assert len(groups) == 1
    assert groups[0][0] == 5
    assert groups[0][1] == [5, 5, 5]

# --- Pairwise ---

@test
def test_pairwise_two_elements_returns_single_pair():
    data: list[int] = [10, 20]
    result: list[tuple[int, int]] = list(itertools.pairwise(data))
    assert len(result) == 1
    assert result[0] == (10, 20)

# --- Starmap ---

@test
def test_starmap_empty_iterable_returns_empty():
    pairs: list[tuple[int, int]] = []
    result: list[int] = list(itertools.starmap(lambda a: int, b: int: a + b, pairs))
    assert len(result) == 0

@test
def test_starmap_single_pair_returns_one_result():
    pairs: list[tuple[int, int]] = [(3, 7)]
    result: list[int] = list(itertools.starmap(lambda a: int, b: int: a * b, pairs))
    assert result == [21]

# --- ZipLongest ---

@test
def test_zip_longest_empty_and_non_empty_fills_with_default():
    empty: list[int] = []
    b: list[int] = [1, 2]
    result: list[tuple[int, int]] = list(itertools.zip_longest(empty, b, 0))
    assert len(result) == 2
    assert result[0] == (0, 1)
    assert result[1] == (0, 2)

@test
def test_zip_longest_both_empty_returns_empty():
    a: list[int] = []
    b: list[int] = []
    result: list[tuple[int, int]] = list(itertools.zip_longest(a, b, 0))
    assert len(result) == 0

@test
def test_zip_longest_with_fillvalue_uses_custom_fillvalue():
    a: list[int] = [1, 2, 3]
    b: list[int] = [4, 5]
    result: list[tuple[int, int]] = list(itertools.zip_longest(a, b, 99))
    assert len(result) == 3
    assert result[0] == (1, 4)
    assert result[1] == (2, 5)
    assert result[2] == (3, 99)

# --- Chain ---

@test
def test_chain_multiple_iterables_concatenates_all():
    a: list[int] = [1, 2]
    b: list[int] = [3, 4]
    c: list[int] = [5]
    result: list[int] = list(itertools.chain(a, b, c))
    assert result == [1, 2, 3, 4, 5]

@test
def test_chain_with_empty_iterable_skips_empty():
    a: list[int] = [1, 2]
    empty: list[int] = []
    result: list[int] = list(itertools.chain(a, empty))
    assert result == [1, 2]

@test
def test_chain_all_empty_returns_empty():
    empty: list[int] = []
    result: list[int] = list(itertools.chain(empty, empty))
    assert len(result) == 0

@test
def test_chain_single_iterable_returns_all_elements():
    a: list[int] = [42]
    result: list[int] = list(itertools.chain(a))
    assert result == [42]

# --- Accumulate ---

@test
def test_accumulate_default_sum_function_returns_cumulative_sums():
    data: list[int] = [1, 2, 3, 4]
    result: list[int] = list(itertools.accumulate(data))
    assert result == [1, 3, 6, 10]
