from unittest import assert_raises

import secrets

@test
def test_token_bytes_returns_correct_length():
    result: bytes = secrets.token_bytes(16)
    assert len(result) == 16

@test
def test_token_bytes_default_length_32():
    result: bytes = secrets.token_bytes()
    assert len(result) == 32

@test
def test_token_bytes_zero_returns_empty():
    result: bytes = secrets.token_bytes(0)
    assert len(result) == 0

@test
def test_token_bytes_negative_throws():
    with assert_raises(ValueError):
        secrets.token_bytes(-1)

@test
def test_token_hex_returns_correct_length():
    result: str = secrets.token_hex(16)
    assert len(result) == 32

@test
def test_token_hex_contains_only_hex_chars():
    result: str = secrets.token_hex(32)
    # Verify all characters are hex digits
    valid: bool = True
    for c in result:
        if c not in "0123456789abcdef":
            valid = False
    assert valid

@test
def test_token_hex_zero_returns_empty():
    result: str = secrets.token_hex(0)
    assert len(result) == 0

@test
def test_token_urlsafe_returns_url_safe_chars():
    result: str = secrets.token_urlsafe(32)
    # Verify all characters are URL-safe base64
    valid: bool = True
    for c in result:
        if c not in "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-":
            valid = False
    assert valid

@test
def test_token_urlsafe_zero_returns_empty():
    result: str = secrets.token_urlsafe(0)
    assert len(result) == 0

@test
def test_randbelow_returns_in_range():
    i: int = 0
    while i < 100:
        val: int = secrets.randbelow(10)
        assert val >= 0
        assert val < 10
        i = i + 1

@test
def test_randbelow_one_always_returns_zero():
    i: int = 0
    while i < 10:
        assert secrets.randbelow(1) == 0
        i = i + 1

@test
def test_randbelow_zero_throws():
    with assert_raises(ValueError):
        secrets.randbelow(0)

@test
def test_randbelow_negative_throws():
    with assert_raises(ValueError):
        secrets.randbelow(-5)

@test
def test_choice_returns_element_from_list():
    items: list[int] = [10, 20, 30]
    result: int = secrets.choice(items)
    assert result in items

@test
def test_choice_empty_list_throws():
    items: list[int] = []
    with assert_raises(IndexError):
        secrets.choice(items)

@test
def test_compare_digest_matching_strings():
    assert secrets.compare_digest("hello", "hello")

@test
def test_compare_digest_non_matching_strings():
    assert not secrets.compare_digest("hello", "world")

@test
def test_compare_digest_different_lengths():
    assert not secrets.compare_digest("short", "longer string")

@test
def test_compare_digest_empty_strings():
    assert secrets.compare_digest("", "")

@test
def test_compare_digest_matching_bytes():
    x: bytes = b"\x01\x02\x03"
    y: bytes = b"\x01\x02\x03"
    assert secrets.compare_digest(x, y)

@test
def test_compare_digest_non_matching_bytes():
    x: bytes = b"\x01\x02\x03"
    y: bytes = b"\x04\x05\x06"
    assert not secrets.compare_digest(x, y)
