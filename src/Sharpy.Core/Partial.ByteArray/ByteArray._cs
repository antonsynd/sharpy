using System.Numerics;
using Sharpy.Collections.Interfaces;

namespace Sharpy.Core;

public sealed partial class ByteArray : Object, MutableSequence<ByteArray, byte>
{
    private byte[] _data;

    /// <remarks>
    /// The number of bytes logically referred to in this byte array. This
    /// is not the same as capacity.
    /// </remarks>
    private uint _numBytes;

    public ByteArray() {
        _data = [];
        _numBytes = 0;
    }

    private void _EnsureCapacity(uint desiredCapacity) {
        if (_data.Length < desiredCapacity) {
            // Ensure at least twice
            byte[] newData = new byte[desiredCapacity * 2];
            _data.CopyTo(new Span<byte>(newData));
        }
    }

    /// <summary>
    /// Returns the item at the given index in the list.
    /// </summary>
    public byte this[int index]
    {
        get
        {
            return __GetItem__(index);
        }
        set
        {
            __SetItem__(index, value);
        }
    }

    public ByteArray this[int start, int end]
    {
        get
        {
            return this[start, end, 1];
        }
        set
        {
            this[start, end, 1] = value;
        }
    }

    public ByteArray this[int start, int end, int step]
    {
        get
        {
            return __GetItem__(new Slice(start, end, step));
        }
        set
        {
            __SetItem__(new Slice(start, end, step), value);
        }
    }

    public static bool operator true(ByteArray bytes) {
        return bytes.__Bool__();
    }

    public static bool operator false(ByteArray bytes) {
        return !bytes.__Bool__();
    }
}
