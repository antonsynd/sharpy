namespace Sharpy.Core;

public sealed partial class ByteArray
{
    public ByteArray __GetItem__()
    {
        return new ByteArray
        {
            _data = [.. _data]
        };
    }

    public byte __GetItem__(int index)
    {
        index = (int)Sharpy.Index.Normalize(index, (uint)_data.Length, false, false);
        return _data[index];
    }

    public ByteArray __GetItem__(Slice slice)
    {
        if (slice.step == 0)
        {
            throw new ValueError("slice step cannot be zero");
        }

        if (slice.step < 0)
        {
            return [];
        }

        (int start, int end) = ((int, int))Slice.Normalize(slice.start, slice.end, (uint)_data.Count);

        return new ByteArray
        {
            _data = [.. _data.Skip(start).Take(end - start).Where((item, index) => index % slice.step == 0)]
        };
    }

    /// <summary>
    /// Return the number of times x appears in the byte array.
    /// </summary>
    public uint Count(byte x)
    {
        return (uint)_data.Count(x.Equals);
    }

    /// <summary>
    /// Return zero-based index in the byte array of the first byte whose
    /// value is equal to x. Raises a <see cref="ValueError"/> if there is
    /// no such byte.
    /// </summary>
    /// <remarks>
    /// The optional arguments start and end are interpreted as
    /// in the slice notation and are used to limit the search to a
    /// particular subsequence of the byte array. The returned index is
    /// computed relative to the beginning of the full sequence rather than
    /// the start argument.
    /// </remarks>
    public uint Index(byte x, int start = 0, int end = -1)
    {
        int count;

        try
        {
            start = (int)Sharpy.Index.Normalize(start, (uint)_data.Length, false, false);
            count = (int)Sharpy.Index.Normalize(end, (uint)_data.Length, false, false) - start;
        }
        catch (IndexError)
        {
            throw new ValueError($"{x} is not in byte array");
        }

        uint index = 0;

        foreach (var b in _data) {
            if (b == x) {
                return index;
            }

            ++index;
        }


        throw new ValueError($"{x} is not in byte array");
    }
}
