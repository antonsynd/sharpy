using System.Text;

namespace Sharpy.Core;

using static Sharpy.Core.Exports;

public sealed partial class ByteArray
{
    public bool __Bool__()
    {
        if (_data == null) {
            return false;
        }

        if (_data.Length == 0) {
            return false;
        }

        foreach (var b in _data) {
            if (b > 0) {
                return true;
            }
        }

        return false;
    }

    public bool __Eq__(object obj)
    {
        if (obj is ByteArray other)
        {
            if (_data == null && other._data == null)
            {
                return true;
            }

            if (_data == null || other._data == null)
            {
                return false;
            }

            return _data.SequenceEqual(other._data);
        }

        return false;
    }

    public bool __Ne__(object other)
    {
        return !__Eq__(other);
    }

    public int __Hash__()
    {
        if (_data == null) {
            return 0;
        }

        var hash = new HashCode();

        foreach (var b in _data) {
            hash.Add(b);
        }

        return hash.ToHashCode();
    }

    public string __Repr__()
    {
        var builder = new StringBuilder();
        builder.Append('[');

        uint i = 1;
        var numElems = _data.Length;

        foreach (var item in _data)
        {
            builder.Append(Repr(item));

            if (i < numElems)
            {
                builder.Append(", ");
            }

            ++i;
        }

        builder.Append(']');

        return builder.ToString();
    }

    public string __Str__()
    {
        return __Repr__();
    }

    public int __Id__()
    {
        return GetHashCode();
    }
}
