# Derived animal classes module
from animal_base import Animal

class Dog(Animal):
    def __init__(self, name: str):
        super().__init__(name)
    
    @override
    def speak(self) -> str:
        return "Woof!"

class Cat(Animal):
    def __init__(self, name: str):
        super().__init__(name)
    
    @override
    def speak(self) -> str:
        return "Meow!"
