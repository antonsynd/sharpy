# Test: Custom registry with __contains__ for membership filtering and set intersection simulation
class TagRegistry:
    _tags: set[str]
    
    def __init__(self):
        self._tags = set()
    
    def add(self, tag: str) -> None:
        self._tags.add(tag)
    
    def __contains__(self, tag: str) -> bool:
        return tag in self._tags
    
    def size(self) -> int:
        return len(self._tags)

def filter_items(registry: TagRegistry, items: list[str]) -> list[str]:
    result: list[str] = []
    for item in items:
        if item not in registry:
            result.append(item)
    return result

def main():
    active_tags = TagRegistry()
    active_tags.add("urgent")
    active_tags.add("review")
    active_tags.add("approved")
    
    candidates: list[str] = ["urgent", "low-priority", "review", "draft", "approved"]
    
    print(active_tags.size())
    
    filtered = filter_items(active_tags, candidates)
    print(len(filtered))
    
    for tag in candidates:
        if tag in active_tags:
            print(f"active:{tag}")
        else:
            print(f"inactive:{tag}")
