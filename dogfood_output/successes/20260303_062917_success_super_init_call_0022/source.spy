# Test: Subclass providing convenience constructor with computed super call
class Rectangle:
    width: int
    height: int

    def __init__(self, w: int, h: int):
        self.width = w
        self.height = h

class Square(Rectangle):
    def __init__(self, side: int):
        super().__init__(side, side)

def main():
    sq = Square(7)
    print(sq.width)
    print(sq.height)
