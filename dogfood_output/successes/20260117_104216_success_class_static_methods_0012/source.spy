# Testing static methods in a class
class MathHelper:
    pi_approx: int = 3
    
    def square(n: int) -> int:
        return n * n
    
    def cube(n: int) -> int:
        return n * n * n

result1 = MathHelper.square(4)
result2 = MathHelper.cube(3)
print(result1)
print(result2)

# EXPECTED OUTPUT:
# 16
# 27