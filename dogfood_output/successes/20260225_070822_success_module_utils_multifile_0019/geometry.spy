# Base geometry module with Shape class and utilities

PI: float = 3.14159

class Shape:
    def __init__(self):
        pass

    @virtual
    def area(self) -> float:
        return 0.0

    @virtual
    def perimeter(self) -> float:
        return 0.0

def scale_value(value: float, factor: float) -> float:
    return value * factor