# Test boolean variables with logical operations and comparisons

is_active: bool = True
is_locked: bool = False
has_access: bool = True

def main():
    print(is_active)
    print(is_locked)
    print(is_active and has_access)
    print(is_active or is_locked)
    print(not is_locked)

# EXPECTED OUTPUT:
# True
# False
# True
# True
# True