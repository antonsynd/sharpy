from game_entity import Entity

class Monster(Entity):
    health: int
    
    def __init__(self, entity_id: int, health: int):
        super().__init__(entity_id)
        self.health = health
    
    @override
    def describe(self) -> str:
        return "Monster #" + str(self.id) + " (HP: " + str(self.health) + ")"
