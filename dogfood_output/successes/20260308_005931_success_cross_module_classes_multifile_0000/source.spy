from shapes import Circle, Rectangle, Shape
from math_utils import MathHelper, square

def main():
    c = Circle(5.0)
    r = Rectangle(4.0, 3.0)
    print(c.area())
    print(r.area())
    print(MathHelper.PI)
    shapes: list[Shape] = []
    shapes.append(c)
    shapes.append(r)
    for s in shapes:
        print(s.describe())
