class Point:
    x: int
    y: int
    
    def __init__(self, x: int, y: int):
        self.x = x
        self.y = y
    
    def __str__(self) -> str:
        return f"({self.x}, {self.y})"

def main():
    p = Point(3, 7)
    print(p)
    # Test with negative coordinates
    origin = Point(0, 0)
    print(origin)
    # EXPECTED OUTPUT:
    # (3, 7)
    # (0, 0)