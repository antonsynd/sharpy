# Test: Nested tuple unpacking

def main():
    nested: tuple[tuple[int, int], tuple[int, int]] = ((10, 20), (30, 40))
    
    (a, b), (c, d) = nested
    
    print(a + c)
    print(b + d)
    
    triple: tuple[tuple[int, int], int] = ((5, 7), 9)
    (x, y), z = triple
    print(x + y + z)

# EXPECTED OUTPUT:
# 40
# 60
# 21