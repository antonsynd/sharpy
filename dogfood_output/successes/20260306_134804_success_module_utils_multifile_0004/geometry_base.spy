# Base module providing geometry interfaces, enums, and abstract base classes

interface IMeasurable:
    def area(self) -> float: ...

interface IDisplayable:
    def display(self) -> str: ...

enum Color:
    RED = 1
    GREEN = 2
    BLUE = 3
    YELLOW = 4

@abstract
class ShapeBase:
    _color: Color
    
    def __init__(self, color: Color):
        self._color = color
    
    @virtual
    def get_color(self) -> Color:
        return self._color
