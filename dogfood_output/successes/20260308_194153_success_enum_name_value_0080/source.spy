enum PriorityLevel:
    LOW = 3
    MEDIUM = 5
    HIGH = 8
    CRITICAL = 13

def display_priority(p: PriorityLevel) -> str:
    name = p.name
    value = p.value
    return f"{name}={value}"

def main():
    total: int = 0
    
    for level in PriorityLevel:
        n = level.name
        v = level.value
        print(n)
        print(v)
        total += v
    
    print(total)
    
    p: PriorityLevel = PriorityLevel.HIGH
    display = display_priority(p)
    print(display)
