# Generic function returning a list pair
def pair[T](a: T, b: T) -> list[T]:
    result: list[T] = []
    result.append(a)
    result.append(b)
    return result

def main():
    nums = pair[int](5, 9)
    print(len(nums))

    words = pair[str]("hi", "bye")
    print(words[0])

# EXPECTED OUTPUT:
# 2
# hi