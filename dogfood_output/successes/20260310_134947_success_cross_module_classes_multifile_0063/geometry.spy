# Base geometry module - defines abstract shapes and interfaces

interface IDrawable:
    def draw(self) -> str: ...

@abstract
class Shape:
    name: str
    
    def __init__(self, name: str):
        self.name = name
    
    @abstract
    def area(self) -> float:
        ...
    
    @virtual
    def describe(self) -> str:
        return f"Shape: {self.name}"
