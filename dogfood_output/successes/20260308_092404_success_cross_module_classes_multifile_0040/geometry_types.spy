interface IMeasurable:
    @abstract
    def measure(self) -> float: ...

    @abstract
    def get_dimensions(self) -> str: ...

enum Unit:
    METRIC = 0
    IMPERIAL = 1

struct Dimension:
    width: float
    height: float
    
    def __init__(self, w: float, h: float):
        self.width = w
        self.height = h
