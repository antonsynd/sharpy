# Simple dict literal with integer keys and string values
def main():
    http_codes: dict[int, str] = {200: "OK", 404: "Not Found", 500: "Server Error"}
    print(http_codes[200])
    print(http_codes[404])
    msg: str = http_codes[500]
    print(msg)

# EXPECTED OUTPUT:
# OK
# Not Found
# Server Error