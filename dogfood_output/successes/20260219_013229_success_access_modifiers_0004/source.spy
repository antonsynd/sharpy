# Simple access modifier test
class Counter:
    value: int
    
    def __init__(self, start: int):
        self.value = start
    
    @private
    def double(self) -> int:
        return self.value * 2
    
    @protected
    def triple(self) -> int:
        return self.value * 3
    
    def calculate(self) -> int:
        return self.double() + self.triple()

def main():
    c = Counter(5)
    result = c.calculate()
    print(result)
    
    # EXPECTED OUTPUT:
    # 25