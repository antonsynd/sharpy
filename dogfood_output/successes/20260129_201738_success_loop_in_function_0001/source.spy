# Test: loop in function with accumulator pattern
def sum_evens(limit: int) -> int:
    total: int = 0
    i: int = 0
    while i <= limit:
        if i % 2 == 0:
            total += i
        i += 1
    return total

def main():
    result: int = sum_evens(10)
    print(result)

# EXPECTED OUTPUT:
# 30