from vehicles import Vehicle

class Car(Vehicle):
    wheels: int
    
    def __init__(self, brand: str, wheels: int):
        super().__init__(brand)
        self.wheels = wheels
    
    @override
    def describe(self) -> str:
        return "Car: " + self.brand + " with " + str(self.wheels) + " wheels"
    
    @override
    def move(self) -> str:
        return "Driving on " + str(self.wheels) + " wheels"
