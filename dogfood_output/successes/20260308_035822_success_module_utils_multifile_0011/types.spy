# Module providing shared types: interfaces, enums, and structs
interface Identifiable:
    def get_id(self) -> str: ...

enum Status:
    ACTIVE = 1
    INACTIVE = 2
    PENDING = 3

struct Metadata:
    key: str
    value: int

    def __init__(self, key: str, value: int):
        self.key = key
        self.value = value
