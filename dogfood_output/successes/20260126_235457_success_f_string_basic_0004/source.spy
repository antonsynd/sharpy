# Test f-string basic interpolation with simple expressions

def main():
    name: str = "Alice"
    age: int = 25
    score: float = 87.5
    
    print(f"Hello, {name}!")
    print(f"You are {age} years old")
    print(f"Score: {score}")
    print(f"Next year: {age + 1}")

# EXPECTED OUTPUT:
# Hello, Alice!
# You are 25 years old
# Score: 87.5
# Next year: 26