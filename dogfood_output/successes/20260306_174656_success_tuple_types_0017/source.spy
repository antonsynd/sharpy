def main():
    # Tuple type annotation with values
    a: tuple[int, int] = (3, 7)
    b: tuple[int, int] = (3, 9)
    
    # Access tuple elements by index
    print(a[0])
    print(a[1])
    
    # Unpack tuples
    x, y = b
    print(x)
    print(y)
    
    # Calculate and print individual comparisons manually
    first_less: bool = a[0] < b[0]
    second_less: bool = a[1] < b[1]
    print(first_less)
    print(second_less)
