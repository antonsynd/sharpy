# Test arithmetic operators with negative numbers and mixed operations
x: int = -8
y: int = 3
z: int = 5

addition: int = x + y
subtraction: int = z - x
multiplication: int = x * y
floor_division: int = x // y
modulo: int = z % y
exponentiation: int = y ** 2

def main():
    print(addition)
    print(subtraction)
    print(multiplication)
    print(floor_division)
    print(modulo)
    print(exponentiation)

# EXPECTED OUTPUT:
# -5
# 13
# -24
# -3
# 2
# 9