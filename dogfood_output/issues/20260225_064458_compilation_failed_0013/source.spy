class Counter:
    _val: int
    def __init__(self, v: int):
        self._val = v
    
    @virtual
    def get(self) -> int:
        return self._val

class DoublingCounter(Counter):
    @override
    def get(self) -> int:
        return self._val * 2

def main():
    c = Counter(7)
    d = DoublingCounter(7)
    print(c.get())
    print(d.get())
    # EXPECTED OUTPUT:
    # 7
    # 14