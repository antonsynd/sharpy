# Test optional unwrap and unwrap_or methods
def main():
    x: int? = Some(42)
    y: int? = None()
    
    # Test unwrap on Some
    print(x.unwrap())
    
    # Test unwrap_or on None
    print(y.unwrap_or(99))
    
    # Test unwrap_or on Some (should return wrapped value)
    print(x.unwrap_or(0))

# EXPECTED OUTPUT:
# 42
# 99
# 42