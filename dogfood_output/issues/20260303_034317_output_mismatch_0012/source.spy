# Test: Basic try/except block catching ZeroDivisionError  
# Tests: try block execution, exception catching, control flow transfer

def main():
    x: int = 5
    y: int = 0
    z: int = 2
    
    try:
        a: int = x * z
        b: int = a // y
        print(b)
    except ZeroDivisionError:
        print(999)
