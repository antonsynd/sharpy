# Test: Basic .NET import and usage
from system import Math

def main():
    # Use Math.PI constant
    print(Math.PI)
    
    # Use Math.Abs method
    print(Math.Abs(-42))
    
    # Basic arithmetic with Math values
    r: float = 5.0
    area: float = Math.PI * r * r
    print(area)
    
    # Compare values
    print(Math.Max(10, 25))
    print(Math.Min(-5, 3))
    
    # Round value
    print(Math.Round(3.7))

# EXPECTED OUTPUT:
# 3.141592653589793
# 42
# 78.53981633974483
# 25
# -5
# 4