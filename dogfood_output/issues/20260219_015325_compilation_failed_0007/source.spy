# Test: Nullable types with null coalescing and conditional operators
def main():
    score: int? = None()
    display: str = str(score ?? 0)
    print(display)

    name: str? = "Sharpy"
    length: int? = name?.len()
    result: str = str(length ?? -1)
    print(result)

    name2: str? = None()
    length2: int? = name2?.len()
    print(str(length2 ?? -1))

# EXPECTED OUTPUT:
# 0
# 6
# -1