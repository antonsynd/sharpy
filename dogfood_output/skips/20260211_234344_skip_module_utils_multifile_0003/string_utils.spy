# Module providing string utility functions

def count_vowels(text: str) -> int:
    vowels: str = "aeiouAEIOU"
    count: int = 0
    i: int = 0
    while i < len(text):
        char: str = text[i:i+1]
        if char in vowels:
            count += 1
        i += 1
    return count

def reverse_string(text: str) -> str:
    result: str = ""
    i: int = len(text) - 1
    while i >= 0:
        result += text[i:i+1]
        i -= 1
    return result