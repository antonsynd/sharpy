# Type definitions module

struct Point:
    x: float
    y: float

    def __init__(self, x: float, y: float):
        self.x = x
        self.y = y

struct Color:
    r: int
    g: int
    b: int

    def __init__(self, r: int, g: int, b: int):
        self.r = r
        self.g = g
        self.b = b

    def __str__(self) -> str:
        return f"Color({self.r}, {self.g}, {self.b})"

class Status:
    ACTIVE: int = 1
    INACTIVE: int = 0
    PENDING: int = 2