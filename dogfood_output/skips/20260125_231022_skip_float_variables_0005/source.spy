# Test: float variables with arithmetic operations and type inference

def main():
    pi: float = 3.14159
    radius: float = 2.5
    
    area = pi * radius * radius
    circumference = 2.0 * pi * radius
    
    print(area)
    print(circumference)

# EXPECTED OUTPUT:
# 19.634937500000003
# 15.70795