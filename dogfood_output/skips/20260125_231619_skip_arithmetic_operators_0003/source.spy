# Test arithmetic operators with remainder and exponentiation
def main():
    base: int = 7
    exponent: int = 2
    divisor: int = 3
    
    power_result: int = base ** exponent
    remainder: int = power_result % divisor
    quotient: int = power_result // divisor
    
    print(power_result)
    print(quotient)
    print(remainder)

# EXPECTED OUTPUT:
# 49
# 16
# 1