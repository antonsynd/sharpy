import sys
from sys import stderr

class Person:
    name: str
    age: int

    def __init__(self, name: str, age: int):
        self.name = name
        self.age = age

    def greet(self) -> str:
        return f"Hello, I'm {self.name}!"

def main():
    p = Person("Alice", 30)
    print(p.greet())
