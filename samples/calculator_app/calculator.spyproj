<?xml version="1.0" encoding="utf-8"?>
<Project>
    <PropertyGroup>
        <RootNamespace>Calculator</RootNamespace>
        <OutputType>exe</OutputType>
        <Configuration>Debug</Configuration>
    </PropertyGroup>
    <ItemGroup>
        <!-- Include all Sharpy files in src/ and subdirectories -->
        <SpyFile Include="src/**/*.spy" />
    </ItemGroup>
</Project>
